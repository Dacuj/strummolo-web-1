# Header di sicurezza HTTP per Cloudflare Pages.
# ATTENZIONE: Cloudflare Pages NON sovrascrive gli header tra regole che combaciano:
# li SOMMA. Una richiesta a /admin/ combacia sia con /admin/* sia con /*, quindi
# riceverebbe due header Content-Security-Policy. Per evitare che la CSP restrittiva
# di /* venga applicata in intersezione (bloccando Decap CMS), /admin/* la stacca con "! ".

# --- Pannello CMS: policy permissiva (Decap/NetlifyCMS carica da CDN esterne) ---
/admin/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  # Stacca la CSP restrittiva ereditata dalla regola /* (Cloudflare somma gli header
  # tra regole che combaciano: senza questo "!" il browser applicherebbe entrambe
  # le CSP in intersezione, bloccando gli script esterni di Decap CMS).
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; img-src 'self' data: blob: https:; connect-src 'self' https:; frame-src 'self' https:;

# --- Tutto il resto del sito: policy restrittiva ---
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; img-src 'self' data: https://res.cloudinary.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://chat-api.davidecucciardi.workers.dev; upgrade-insecure-requests
