</head>
<body class="disclaimer-mode">

    <!-- VIEW 1: DISCLAIMER -->
    <main id="disclaimer-view" class="terminal-container" style="display: none;">
        <div class="content-disclaimer">
            <p>
             You may enter this live chat at any time by accepting that you will leave a permanent digital footprint upon any and all of our servers and all related databases and all logs thereof, whether generated under the terms of this agreement or otherwise. We disclaim any and all responsibility immediately and without notice from us if, in their sole discretion, any user chooses to write whatever they want, regardless of any term or provision of this agreement. Upon entry, you must accept all risks associated with materials published on this site and any and all of our other sites and all copies thereof, whether made under the terms of this agreement or otherwise.
            </p>
            
            <form id="entry-form" class="entry-form">
                <input type="text" id="nickname" class="nick-input" placeholder="username" required maxlength="20" autocomplete="off" />
                <button type="submit" class="accept-btn">ACCEPT</button>
            </form>
        </div>
    </main>

    <!-- VIEW 2: BACHECA -->
    <div id="chat-view" style="display: none;">
        <svg class="jodi-bg" viewBox="0 0 100 100" preserveAspectRatio="none">
            {cyanPaths.map(path => ( <path d={path} fill="none" stroke="#00ffff" stroke-width="0.3" vector-effect="non-scaling-stroke" class="cyan-line" /> ))}
            {topoPaths.map(path => ( <path d={path} fill="none" stroke="#ffff00" stroke-width="0.2" vector-effect="non-scaling-stroke" /> ))}
            {mapNumbers.map(num => ( <text x={num.x} y={num.y} fill="#ffff00" font-size="2" font-family="monospace">{num.val}</text> ))}
            <circle cx="20" cy="80" r="1.5" fill="none" stroke="#0000ff" stroke-width="0.5" vector-effect="non-scaling-stroke" />
            <circle cx="20" cy="80" r="0.4" fill="#0000ff" />
            <circle cx="60" cy="40" r="1.5" fill="none" stroke="#0000ff" stroke-width="0.5" vector-effect="non-scaling-stroke" />
            <circle cx="60" cy="40" r="0.4" fill="#0000ff" />
        </svg>

        <main class="ui-layer">
            <a href="/" class="home-link">"strummolo123=</a>
            <div id="whiteboard" class="articles-container"></div>
        </main>

        <div class="controls-wrapper">
            <div class="load-more-container">
                <button id="load-more-btn">LOAD MORE_</button>
            </div>
            <form id="chat-form">
                <input type="text" id="chat-input" placeholder="Scrivi..." required maxlength="250" autocomplete="off" />
                <button type="submit" id="submit-btn">INVIA</button>
            </form>
        </div>
    </div>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const disclaimerView = document.getElementById('disclaimer-view');
    const chatView = document.getElementById('chat-view');
    const entryForm = document.getElementById('entry-form');
    const nickInput = document.getElementById('nickname');
    
    let userNickname = localStorage.getItem('sturmmolo_nick');

    function showChat() {
        document.body.classList.remove('disclaimer-mode');
        document.body.classList.add('chat-mode');
        disclaimerView.style.display = 'none';
        chatView.style.display = 'block';
        initChat(); 
    }

    function showDisclaimer() {
        document.body.classList.remove('chat-mode');
        document.body.classList.add('disclaimer-mode');
        disclaimerView.style.display = 'flex';
        chatView.style.display = 'none';
    }

    if (userNickname) {
        showChat();
    } else {
        showDisclaimer();
    }

    entryForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const nickname = nickInput.value.trim();
        
        if (nickname) {
            localStorage.setItem('sturmmolo_nick', nickname);
            userNickname = nickname; 
            showChat();
        }
    });

    function initChat() {
        const API_URL = "https://chat-api.davidecucciardi.workers.dev/messages";
        
        const whiteboard = document.getElementById('whiteboard');
        const chatForm = document.getElementById('chat-form');
        const chatInput = document.getElementById('chat-input');
        const submitBtn = document.getElementById('submit-btn');
        const loadMoreBtn = document.getElementById('load-more-btn');

        const leftPositions = [10, 55, 20, 60, 15, 50, 25];
        const glitchSymbols = ['†', 'º', '‡', '±', ''];

        let allMessages = [];
        let displayedCount = 0;
        const LIMIT_PER_PAGE = 15;
        let isSending = false;

        function escapeHTML(str) {
            if (!str) return '';
            return str.replace(/[&<>'"]/g, 
                tag => ({
                    '&': '&amp;', '<': '&lt;', '>': '&gt;',
                    "'": '&#39;', '"': '&quot;'
                }[tag])
            );
        }

        function hashCode(str) {
            let hash = 0;
            for (let i = 0; i < str.length; i++) {
                hash = (hash << 5) - hash + str.charCodeAt(i);
                hash |= 0; 
            }
            return Math.abs(hash);
        }

        function getDeterministicRandom(seed) {
            const x = Math.sin(seed) * 10000;
            return x - Math.floor(x);
        }

        function createMessageNode(msg) {
            const stringSeed = msg.content + (msg.nickname || '');
            const baseSeed = hashCode(stringSeed);
            
            const posIndex = Math.floor(getDeterministicRandom(baseSeed) * leftPositions.length);
            const posLeft = leftPositions[posIndex];
            
            const symbolIndex = Math.floor(getDeterministicRandom(baseSeed + 1) * glitchSymbols.length);
            const symbol = glitchSymbols[symbolIndex];

            const safeContent = escapeHTML(msg.content);
            const safeNickname = escapeHTML(msg.nickname || '131.24.167');

            const wrapper = document.createElement('div');
            wrapper.className = 'article-node';
            wrapper.style.setProperty('--offset-x', `${posLeft}vw`);

            wrapper.innerHTML = `
                <div class="main-title">${safeContent.toUpperCase()}${symbol}</div>
                <div class="sub-title">${safeNickname}</div>
            `;
            return wrapper;
        }

        async function loadInitialMessages() {
            if (whiteboard.innerHTML !== '') return; 
            
            try {
                const res = await fetch(API_URL);
                const data = await res.json();
                
                data.sort((a, b) => b.id - a.id); 
                allMessages = data; 
                renderNextChunk();
            } catch (err) {
                console.error("Errore", err);
                whiteboard.innerHTML = '<div class="article-node" style="--offset-x: 10vw;"><div class="main-title">SYS.ERR</div></div>';
            }
        }

        function renderNextChunk() {
            const fragment = document.createDocumentFragment();
            const messagesToRender = allMessages.slice(displayedCount, displayedCount + LIMIT_PER_PAGE);

            messagesToRender.forEach(msg => {
                fragment.appendChild(createMessageNode(msg));
            });

            whiteboard.appendChild(fragment);
            displayedCount += messagesToRender.length;

            if (displayedCount >= allMessages.length) {
                loadMoreBtn.style.display = 'none';
            } else {
                loadMoreBtn.style.display = 'inline-block';
            }
        }

        // Listener pulito senza rimpiazzi o cloni
        loadMoreBtn.addEventListener('click', renderNextChunk);

        // Listener per invio messaggi
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (isSending) return;
            
            const content = chatInput.value.trim();
            const nickname = userNickname || '131.24.167'; 

            if (!content || content.length > 250) return;

            isSending = true;
            submitBtn.disabled = true;
            chatInput.disabled = true;
            const originalBtnText = submitBtn.innerText;
            submitBtn.innerText = "WAIT";

            try {
                await fetch(API_URL, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ content, nickname })
                });

                const newMsgData = { 
                    id: Date.now(), 
                    content, 
                    nickname: nickname
                };
                
                const newNode = createMessageNode(newMsgData);
                whiteboard.prepend(newNode);
                
                allMessages.unshift(newMsgData);
                displayedCount++;
                chatInput.value = ''; 
                
            } catch (err) {
                console.error("Invio fallito", err);
                alert("Errore di connessione.");
            } finally {
                setTimeout(() => {
                    isSending = false;
                    submitBtn.disabled = false;
                    chatInput.disabled = false;
                    submitBtn.innerText = originalBtnText;
                    chatInput.focus();
                }, 3000);
            }
        });

        loadInitialMessages();
    }
});
</script>
</body>
</html>