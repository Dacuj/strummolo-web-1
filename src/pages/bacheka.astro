    }

    #chat-input {
        flex-grow: 1; 
        background-color: #ffffff;
        color: #000000;
        border: 2px inset #ececec; 
        padding: 4px 6px;
        font-family: Arial, sans-serif;
        font-size: 16px; 
        outline: none;
        border-radius: 0;
    }

    #submit-btn {
        pointer-events: auto;
        background-color: #d4d0c8; 
        color: #000000;
        border: 2px outset #ffffff; 
        border-bottom-color: #404040;
        border-right-color: #404040;
        padding: 4px 12px;
        font-family: Arial, sans-serif;
        font-size: 16px; 
        font-weight: bold;
        cursor: pointer;
        border-radius: 0;
    }

    #submit-btn:active {
        border: 2px inset #ffffff;
        border-bottom-color: #404040;
        border-right-color: #404040;
    }

    button:disabled { opacity: 0.5; cursor: not-allowed; }

    @media (max-width: 768px) {
        .main-title { font-size: 20px; text-decoration-thickness: 2px; }
        .sub-title { font-size: 16px; }
        .home-link { font-size: 20px; top: 3%; left: 3%; }
        
        .articles-container { gap: 2.5rem; padding-top: 10vh; } 
        .article-node { margin-left: calc(var(--offset-x) * 0.2); max-width: calc(94vw - calc(var(--offset-x) * 0.2)); }
        .ui-layer { padding-bottom: 180px; } 

