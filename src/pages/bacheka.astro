// src/pages/bacheca.astro
// 1. FUNZIONI GENERATIVE PER L'ARTWORK SVG
const generateCyanLines = () => {
    let paths = [];
    for (let i = 0; i < 8; i++) {
        let path = `M ${Math.random() * 100} ${Math.random() * 10}`;
        for (let j = 0; j < 5; j++) {
            path += ` L ${Math.random() * 100} ${Math.random() * 100}`;
        }
        paths.push(path);
    }
    return paths;
};

const generateTopoLines = () => {
    let paths = [];
    const peaks = [
        { cx: 20, cy: 80, layers: 15, radius: 25 },
        { cx: 60, cy: 40, layers: 20, radius: 35 },
        { cx: 85, cy: 30, layers: 10, radius: 15 }
    ];

    peaks.forEach(peak => {
        for (let l = 1; l <= peak.layers; l++) {
            let points = [];
            let currentRadius = (l / peak.layers) * peak.radius;
            for (let angle = 0; angle < 360; angle += 20) {
                let jitter = (Math.random() - 0.5) * 4; 
                let r = currentRadius + jitter;
                let x = peak.cx + r * Math.cos((angle * Math.PI) / 180);
                let y = peak.cy + r * Math.sin((angle * Math.PI) / 180);
                points.push(`${x},${y}`);
            }
            paths.push(`M ${points.join(' L ')} Z`);
        }
    });
    return paths;
};

const generateNumbers = () => {
    let numbers = [];
    for (let i = 0; i < 30; i++) {
        numbers.push({
            x: Math.random() * 95,
            y: Math.random() * 95,
            val: Math.floor(Math.random() * 40 + 50)
        });
    }
    return numbers;
};

const cyanPaths = generateCyanLines();
const topoPaths = generateTopoLines();
const mapNumbers = generateNumbers();
---

<html lang="it">
<head>
    <meta charset="utf-8" />
    <title>Sturmmolo - Bacheca</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style is:global>
    /* --- RESET & SETUP --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        /* Sfondo a righe verdi e nere */
        background: repeating-linear-gradient(
            0deg,
            #000000,
            #000000 2px,
            #00ff00 2px,
            #00ff00 4px
        );
        min-height: 100vh;
        overflow-x: hidden; 
        overflow-y: auto;   
        font-family: Arial, Helvetica, sans-serif; 
        cursor: crosshair;
    }

    /* --- BACKGROUND SVG --- */
    .jodi-bg {
        position: fixed; 
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1;
        pointer-events: none; 
    }

    .cyan-line {
        animation: glitchPath 4s infinite step-end;
    }

    @keyframes glitchPath {
        90% { stroke-opacity: 1; }
        95% { stroke-opacity: 0.2; }
        100% { stroke-opacity: 1; }
    }

    /* --- LAYER UI HTML --- */
    .ui-layer {
        position: relative;
        width: 100%;
        z-index: 10;
        padding-bottom: 120px; 
    }

    /* --- LAYOUT BACHECA --- */
    .articles-container {
        display: flex;
        flex-direction: column;
        gap: 25vh; 
        padding-top: 15vh; 
    }

    /* --- HOME LINK --- */
    .home-link {
        position: fixed; 
        top: 5%;
        left: 5%;
        color: #0000ff; 
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 26px;
        font-weight: 900;
        letter-spacing: 1px;
        background-color: rgba(0, 0, 0, 0.8); 
        padding: 2px 6px;
        z-index: 100;
    }

    .home-link:hover {
        background-color: #0000ff; 
        color: #ffffff;
        text-decoration: none;
    }

    /* --- STILE MESSAGGI --- */
    .article-node {
        position: relative; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        background-color: rgba(0, 0, 0, 0.8); 
        padding: 4px 8px;
        margin-left: var(--offset-x);
        width: fit-content;
        max-width: calc(92vw - var(--offset-x)); 
    }

    .main-title {
        color: #0000ff; 
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 1px;
        white-space: normal; 
        word-wrap: break-word; 
        line-height: 1.1; 
    }

    .sub-title {
        color: #0000ff; 
        text-decoration: underline;
        text-decoration-thickness: 2px;
        font-size: 22px;
        font-weight: 700;
        margin-top: 2px;
        pointer-events: none;
        word-wrap: break-word;
    }

    /* --- BARRA INPUT SOLO STRUTTURA --- */
    .controls-wrapper {
        position: fixed;
        bottom: 20px; 
        left: 0;
        width: 100vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 1000;
        pointer-events: none; /* Permette i click sullo sfondo */
    }

    form {
        pointer-events: auto; /* Riattiva i click sul form */
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 5px; /* Minima spaziatura di base per non accavallare gli elementi */
    }

    #load-more-btn {
        pointer-events: auto;
        display: none;
        margin-bottom: 10px;
    }

    /* --- MOBILE --- */
    @media (max-width: 768px) {
        .main-title { font-size: 20px; text-decoration-thickness: 2px; }
        .sub-title { font-size: 16px; }
        .home-link { font-size: 20px; top: 3%; left: 3%; }
        .articles-container { gap: 20vh; padding-top: 10vh; } 
        
        .article-node {
            margin-left: calc(var(--offset-x) * 0.2);
            max-width: calc(94vw - calc(var(--offset-x) * 0.2));
        }
        .ui-layer { padding-bottom: 180px; } 
    }
    </style>
</head>
<body>
  <!-- BACKGROUND SVG JODI -->
<svg class="jodi-bg" viewBox="0 0 100 100" preserveAspectRatio="none">
    {cyanPaths.map(path => (
        <path d={path} fill="none" stroke="#00ffff" stroke-width="0.3" vector-effect="non-scaling-stroke" class="cyan-line" />
    ))}
    {topoPaths.map(path => (
        <path d={path} fill="none" stroke="#ffff00" stroke-width="0.2" vector-effect="non-scaling-stroke" />
    ))}
    {mapNumbers.map(num => (
        <text x={num.x} y={num.y} fill="#ffff00" font-size="2" font-family="monospace">
            {num.val}
        </text>
    ))}
    <circle cx="20" cy="80" r="1.5" fill="none" stroke="#0000ff" stroke-width="0.5" vector-effect="non-scaling-stroke" />
    <circle cx="20" cy="80" r="0.4" fill="#0000ff" />
    <circle cx="60" cy="40" r="1.5" fill="none" stroke="#0000ff" stroke-width="0.5" vector-effect="non-scaling-stroke" />
    <circle cx="60" cy="40" r="0.4" fill="#0000ff" />
</svg>

<main class="ui-layer">

    <!-- LOGO HOME -->
    <a href="/" class="home-link">
        "strummolo123=
    </a>

    <!-- CONTENITORE MESSAGGI -->
    <div id="whiteboard" class="articles-container">
        <!-- I messaggi si inietteranno qui -->
    </div>

</main>

<!-- FORM FLOTTANTE IN BASSO, NUDO E CRUDO -->
<div class="controls-wrapper">
    <button id="load-more-btn">LOAD MORE_</button>
    
    <form id="chat-form">
        <input type="text" id="chat-nick" placeholder="nome" maxlength="20" autocomplete="off" />
        <input type="text" id="chat-input" placeholder="scrivi un messaggio" required maxlength="250" autocomplete="off" />
        <button type="submit">INVIA</button>
    </form>
</div>

<script>
    const API_URL = "https://chat-api.davidecucciardi.workers.dev/messages";
    
    const whiteboard = document.getElementById('whiteboard');
    const chatForm = document.getElementById('chat-form');
    const chatInput = document.getElementById('chat-input');
    const chatNick = document.getElementById('chat-nick');
    const loadMoreBtn = document.getElementById('load-more-btn');

    const leftPositions = [10, 55, 20, 60, 15, 50, 25];
    const glitchSymbols = ['†', 'º', '‡', '±', ''];

    let allMessages = [];
    let displayedCount = 0;
    const LIMIT_PER_PAGE = 15;

    function hashCode(str) {
        let hash = 0;
        for (let i = 0; i < str.length; i++) {
            hash = (hash << 5) - hash + str.charCodeAt(i);
            hash |= 0; 
        }
        return Math.abs(hash);
    }

    function getDeterministicRandom(seed) {
        const x = Math.sin(seed) * 10000;
        return x - Math.floor(x);
    }

    function createMessageNode(msg) {
        const stringSeed = msg.content + (msg.nickname || '');
        const baseSeed = hashCode(stringSeed);
        
        const posIndex = Math.floor(getDeterministicRandom(baseSeed) * leftPositions.length);
        const posLeft = leftPositions[posIndex];
        
        const symbolIndex = Math.floor(getDeterministicRandom(baseSeed + 1) * glitchSymbols.length);
        const symbol = glitchSymbols[symbolIndex];

        const wrapper = document.createElement('div');
        wrapper.className = 'article-node';
        wrapper.style.setProperty('--offset-x', `${posLeft}vw`);

        wrapper.innerHTML = `
            <div class="main-title">${msg.content.toUpperCase()}${symbol}</div>
            <div class="sub-title">${msg.nickname || '131.24.167'}</div>
        `;
        return wrapper;
    }

    async function loadInitialMessages() {
        try {
            const res = await fetch(API_URL);
            const data = await res.json();
            
            data.sort((a, b) => b.id - a.id); 
            allMessages = data; 
            renderNextChunk();
        } catch (err) {
            console.error("Errore", err);
            whiteboard.innerHTML = '<div class="article-node" style="--offset-x: 10vw;"><div class="main-title">SYS.ERR</div></div>';
        }
    }

    function renderNextChunk() {
        const fragment = document.createDocumentFragment();
        const messagesToRender = allMessages.slice(displayedCount, displayedCount + LIMIT_PER_PAGE);

        messagesToRender.forEach(msg => {
            fragment.appendChild(createMessageNode(msg));
        });

        whiteboard.appendChild(fragment);
        displayedCount += messagesToRender.length;

        if (displayedCount >= allMessages.length) {
            loadMoreBtn.style.display = 'none';
        } else {
            loadMoreBtn.style.display = 'inline-block';
        }
    }

    loadMoreBtn.addEventListener('click', () => {
        renderNextChunk();
    });

    chatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const content = chatInput.value;
        const nickname = chatNick.value;

        if (!content.trim()) return;

        chatInput.value = ''; 
        
        await fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ content, nickname })
        });

        const newMsgData = { 
            id: Date.now(), 
            content, 
            nickname: nickname || '131.24.167' 
        };
        
        const newNode = createMessageNode(newMsgData);
        whiteboard.prepend(newNode);
        
        allMessages.unshift(newMsgData);
        displayedCount++;
    });

    loadInitialMessages();
</script>
</body>
</html>