/* src/pages/more.astro 
  Sturmmolo Museum Exhibition - Minimalist Artist Layout
*/

// Aggiungi qui tutte le foto che vuoi. 
// Il codice genererà automaticamente un pallino per ognuna.
const exhibits = [
  {
    id: 1,
    image: "/img/psq.webp", 
  },
  {
    id: 2,
    image: "/img/mir.webp",
  },
  {
    id: 3,
    image: "/img/mat.webp",
  },
  {
    id: 4,
    image: "/img/spilleWEB.webp",
  },
  {
    id: 5,
    image: "/img/HATEJADORE.webp",
  }
];

// // Generiamo posizioni casuali per i pallini in fase di build per spargerli sull'immagine
// const dotsWithPositions = exhibits.map((exhibit) => ({
//   ...exhibit,
//   // Mantiene i pallini all'interno di un'area sicura (10% - 90%) per non farli uscire dai bordi
//   top: Math.floor(Math.random() * 80) + 10,
//   left: Math.floor(Math.random() * 80) + 10,
// }));

// Distanza minima (in percentuale) che deve esserci tra un pallino e l'altro
const MIN_DISTANCE = 15; 
const dotsWithPositions = [];

for (const exhibit of exhibits) {
  let top, left;
  let isTooClose = true;
  let attempts = 0; // Limite di sicurezza per evitare loop infiniti

  // Continua a cercare coordinate finché non trova un punto abbastanza lontano dagli altri
  while (isTooClose && attempts < 100) {
    top = Math.floor(Math.random() * 80) + 10;
    left = Math.floor(Math.random() * 80) + 10;
    isTooClose = false;

    // Teorema di Pitagora per calcolare la distanza tra il nuovo pallino e quelli già piazzati
    for (const existingDot of dotsWithPositions) {
      const dx = left - existingDot.left;
      const dy = top - existingDot.top;
      const distance = Math.sqrt(dx * dx + dy * dy);

      if (distance < MIN_DISTANCE) {
        isTooClose = true; // Troppo vicino, il loop riparte
        break;
      }
    }
    attempts++;
  }

  dotsWithPositions.push({ ...exhibit, top, left });
}
---

<!DOCTYPE html>
<html lang="it">
<head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>sturmmolo | MUSEUM</title>
</head>
<body>

    <main class="layout-container">
        <div class="left-panel">
            
            <div class="interactive-zone">
                <div id="clock" class="time-display">--:--:--</div>
                
                <img 
                    id="main-exhibit-image" 
                    src={dotsWithPositions[0]?.image || ''} 
                    alt="Sturmmolo Artefact" 
                    draggable="false"
                />

                <div class="dots-container">
                    {dotsWithPositions.map((item, index) => (
                        <button 
                            class={`dot ${index === 0 ? 'active' : ''}`}
                            style={`top: ${item.top}%; left: ${item.left}%;`}
                            data-image={item.image}
                            aria-label={`Mostra immagine ${item.id}`}
                        ></button>
                    ))}
                </div>
            </div>

            <div class="black-zone"></div>
        </div>

        <div class="right-panel"></div>
    </main>

    <script>
        // --- LOGICA OROLOGIO (Formato simile allo screen: 6:48:54 P.M.) ---
        function updateTime() {
            const now = new Date();
            let hours = now.getHours();
            let minutes = now.getMinutes().toString().padStart(2, '0');
            let seconds = now.getSeconds().toString().padStart(2, '0');
            const ampm = hours >= 12 ? 'P.M.' : 'A.M.';
            
            hours = hours % 12;
            hours = hours ? hours : 12; // converte l'ora '0' in '12'
            
            const timeString = `${hours}:${minutes}:${seconds} ${ampm}`;
            const clockElement = document.getElementById('clock');
            if (clockElement) clockElement.innerText = timeString;
        }
        
        setInterval(updateTime, 1000);
        updateTime();

        // --- LOGICA CAMBIO IMMAGINE CON I PALLINI ---
        const dots = document.querySelectorAll('.dot');
        const mainImage = document.getElementById('main-exhibit-image') as HTMLImageElement;

        dots.forEach(dot => {
            dot.addEventListener('click', (e) => {
                const target = e.target as HTMLButtonElement;
                
                // Cambia la sorgente dell'immagine
                const newImageSrc = target.getAttribute('data-image');
                if (newImageSrc && mainImage) {
                    mainImage.src = newImageSrc;
                }

                // Aggiorna lo stato visivo del pallino attivo
                dots.forEach(d => d.classList.remove('active'));
                target.classList.add('active');
            });
        });
    </script>

</body>
</html>

<style is:global>
    /* --- RESET TOTALE --- */
    * { 
        margin: 0; 
        padding: 0; 
        box-sizing: border-box; 
    }

    body, html {
        width: 100vw;
        height: 100vh;
        overflow: hidden; /* Blocca lo scroll, la pagina è fissa */
        background-color: #000;
        font-family: monospace;
    }

    /* --- STRUTTURA A BLOCCHI --- */
    .layout-container {
        display: flex;
        width: 100vw;
        height: 100vh;
    }

    .left-panel {
        width: 50vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .right-panel {
        width: 50vw;
        height: 100vh;
        background-color: #cccccc; /* Il grigio dello screenshot */
    }

    /* --- ZONE SINISTRE --- */
    .interactive-zone {
        width: 100%;
        height: 50vh; /* Esattamente la metà superiore */
        position: relative;
        background-color: #000;
    }

    .black-zone {
        width: 100%;
        height: 50vh; /* Esattamente la metà inferiore */
        background-color: #000;
    }

    /* --- ELEMENTI INTERATTIVI --- */
    .time-display {
        position: absolute;
        top: 8px;
        left: 8px;
        background-color: #fff;
        color: #000;
        padding: 2px 6px;
        font-size: 11px;
        z-index: 10;
        border: 1px solid #000;
    }

    #main-exhibit-image {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Riempie il rettangolo in modo fisso, tagliando gli eccessi */
        object-position: center;
        /* Rimuovi o commenta la riga sotto se vuoi le foto a colori. 
           L'ho inserita per replicare l'effetto bianco e nero della reference */
        filter: grayscale(100%); 
        display: block;
    }

    /* --- STILE PALLINI --- */
    .dots-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none; /* Permette di cliccare attraverso il contenitore */
    }

    .dot {
        position: absolute;
        width: 12px;
        height: 12px;
        background-color: #fff;
        border: 2px solid #fff;
        border-radius: 50%;
        cursor: pointer;
        transform: translate(-50%, -50%);
        pointer-events: auto; /* Riattiva il click solo sui pallini */
        box-shadow: 0 0 3px rgba(0,0,0,0.5); /* Leggera ombra per renderli visibili su sfondi chiari */
        transition: background-color 0.2s;
    }

    /* Il pallino dell'immagine attualmente visualizzata (colore interno scuro come nello screen) */
    .dot.active {
        background-color: #666; 
    }

    /* --- MOBILE VIEW --- */
    @media (max-width: 768px) {
        .layout-container {
            flex-direction: column; /* Assicura che gli elementi si impilino se necessario */
        }

        .right-panel {
            display: none; /* Rimuove completamente la zona grigia */
        }

        .left-panel {
            width: 100vw; /* Fa espandere la sezione foto e il blocco nero a tutto schermo */
        }

        /* Opzionale: puoi ingrandire leggermente l'orologio su mobile se risulta troppo piccolo */
        .time-display {
            font-size: 14px; 
            padding: 4px 8px;
        }

        /* Opzionale: rende i pallini leggermente più grandi per facilitare il tap col dito */
        .dot {
            width: 16px;
            height: 16px;
        }
    }
</style>