<script>
    // MOTORE WIREFRAME 2D PURO - Stile Net.Art anni '90
    const canvas = document.getElementById("bg-canvas");
    const ctx = canvas.getContext("2d");

    function renderWireframe() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        
        ctx.fillStyle = "#000000";
        ctx.fillRect(0, 0, canvas.width, canvas.height);

        ctx.strokeStyle = "#FFFF00";
        ctx.lineWidth = 1;
        ctx.imageSmoothingEnabled = false; 

        const cols = 45;
        const rows = 30;
        
        // Check per applicare la prospettiva adattiva
        const isMobile = window.innerWidth <= 768;
        
        // Calcoli proporzionali per evitare che il wireframe "scappi" dallo schermo mobile
        // La larghezza scala con lo schermo, l'altezza scala in base alla viewport
        const spreadX = isMobile ? canvas.width * 1.4 : 800;
        const stepY = isMobile ? (canvas.height / 30) : 15; 
        const zMult = isMobile ? 50 : 40; 

        function drawMesh(offsetY) {
            ctx.beginPath();
            for (let y = 0; y < rows - 1; y++) {
                for (let x = 0; x < cols - 1; x++) {
                    
                    let getPoint = (ix, iy) => {
                        let nx = (ix / cols) * 2 - 1; 
                        
                        let z = 0;
                        if (nx < -0.2) {
                            z = Math.sin(nx * 8 + iy * 0.2) * 0.2; 
                        } else if (nx > 0.3) {
                            z = (Math.sin(nx * 15) * Math.cos(iy * 0.8)) * (nx * 3); 
                        } else {
                            z = -1.5 + Math.abs(nx) * 2; 
                        }

                        let scale = 300 / (iy + 5); 
                        
                        // Posizionamento orizzontale e verticale dinamico
                        let px = (canvas.width / 2) + (nx * spreadX * (scale / 15));
                        let py = offsetY + (iy * stepY) - (z * zMult * (scale / 10));
                        return [px, py];
                    };

                    let p1 = getPoint(x, y);
                    let p2 = getPoint(x + 1, y);
                    let p3 = getPoint(x, y + 1);

                    ctx.moveTo(p1[0], p1[1]);
                    ctx.lineTo(p2[0], p2[1]);
                    ctx.moveTo(p1[0], p1[1]);
                    ctx.lineTo(p3[0], p3[1]);
                }
            }
            ctx.stroke();
        }

        // Su mobile partiamo più in alto e distribuiamo le due griglie per coprire l'intero schermo
        const offsetTop = isMobile ? canvas.height * 0.05 : canvas.height * 0.15;
        const offsetBottom = isMobile ? canvas.height * 0.50 : canvas.height * 0.65;

        drawMesh(offsetTop);
        drawMesh(offsetBottom);
    }

    window.addEventListener("resize", renderWireframe);
    renderWireframe();

</script>

