<style is:global>
    /* --- RESET E LOCK SCHERMO --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #000000;
        color: #ffff00; 
        height: 100%;
        width: 100%;
        overflow: hidden; 
        position: fixed; 
        touch-action: none; 
        
        font-family: 'Courier New', Courier, Fixedsys, Terminal, monospace;
        font-weight: bold;
        -webkit-font-smoothing: none;
        font-smooth: never;
        cursor: url('https://cur.cursors-4u.net/nature/nat-10/nat926.cur'), auto;
    }

    /* --- SFONDO CANVAS JODI --- */
    #bg-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
    }

    /* --- HEADER (Desktop intatto) --- */
    header {
        width: 100%;
        padding: 20px;
        display: flex;
        align-items: flex-start; 
        justify-content: space-between;
        background-color: transparent; 
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
        pointer-events: none; 
    }

    .logo, .navbar {
        pointer-events: auto;
    }

    .logo {
        font-family: 'Press Start 2P', cursive;
        font-size: 0.7rem;
        text-decoration: none;
        display: flex;
        gap: 2px;
        text-shadow: 2px 2px 0px #000; 
        background: rgba(0,0,0,0.8);
        padding: 8px;
        margin-top: 10px; 
        transform: rotate(-1deg); 
        flex-shrink: 0;
    }

    .logo span:nth-child(1) { color: #ea4335; } 
    .logo span:nth-child(2) { color: #fbbc05; } 
    .logo span:nth-child(3) { color: #4285f4; } 
    .logo span:nth-child(4) { color: #34a853; } 
    .logo span:nth-child(5) { color: #ea4335; } 
    .logo span:nth-child(6) { color: #fff; }    
    .logo span:nth-child(7) { color: #fff; }    
    .logo .arrows { color: #4285f4; margin-left: 5px; }
    .logo:hover { opacity: 0.8; }

    .navbar {
        display: flex;
        align-items: flex-start;
        flex-grow: 1; 
        padding-left: 60px; 
        padding-right: 20px;
    }

    .nav-link {
        font-family: 'Inter', 'Helvetica Neue', 'Arial', sans-serif; 
        font-weight: 300; 
        font-size: 2.8rem; 
        letter-spacing: -2px; 
        color: #000; 
        text-decoration: none;
        text-transform: uppercase; 
        padding: 0px 2px; 
        line-height: 0.75; 
        background: #fff; 
        border: none;
        transition: transform 0.1s, background 0.1s, color 0.1s;
        display: inline-block; 
        box-shadow: 2px 2px 0px rgba(0,0,0,0.5); 
    }

    .navbar a:nth-child(1) { margin-right: auto; margin-top: 0px; transform: rotate(-2deg); }
    .navbar a:nth-child(2) { margin-top: 15px; margin-right: 40px; transform: rotate(3deg); }
    .navbar a:nth-child(3) { margin-top: 5px; transform: rotate(-3deg); }

    .nav-link:hover { 
        transform: scale(1.02) rotate(0deg) !important;
        z-index: 10;
        background: #000; 
        color: #fff;
    }

    /* --- TESTO STILE JODI (Desktop) --- */
    .jodi-content {
        padding-top: 25vh; 
        padding-left: 5vw;
        padding-right: 5vw;
        width: 100%;
        height: 100%;
        z-index: 10;
        position: relative;
        pointer-events: none;
        box-sizing: border-box;
    }

    .raw-text {
        font-family: 'Courier New', Courier, Terminal, monospace;
        font-size: 2vw; 
        line-height: 1.1;
        white-space: pre-wrap; 
        word-wrap: break-word;
        max-width: 100%;
        color: #ffff00;
        text-shadow: 2px 2px 0px #000, -1px -1px 0px #000, 1px -1px 0px #000, -1px 1px 0px #000, 1px 1px 0px #000; 
        pointer-events: auto;
        user-select: text; 
    }

    /* --- SPILLA VINTAGE --- */
    .pin-container {
        position: fixed;
        bottom: 40px;
        right: 40px;
        width: 130px; 
        height: 130px;
        z-index: 2000; 
        pointer-events: auto;
    }

    .pin-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
    }

    /* --- MEDIA QUERIES (Modificate rigorosamente per Mobile) --- */
    @media (max-width: 768px) {
        
        header { 
            padding: 10px; 
            flex-direction: column; 
            gap: 10px; 
            background-color: rgba(0,0,0,0.8);
            pointer-events: auto; 
        }
        .logo { 
            font-size: 1rem; 
            width: 100%; 
            justify-content: center; 
            margin-top: 0; 
            transform: none; 
        }
        .navbar { 
            gap: 15px; 
            width: 100%; 
            justify-content: center; 
            padding-right: 0;
            padding-left: 0;
        }
        .navbar a:nth-child(n) { 
            margin-top: 0; 
            margin-right: 0; 
            transform: none; 
        }
        .nav-link { 
            font-size: 1.5rem; 
            line-height: 0.8; 
            letter-spacing: -1px; 
        }

        /* Container del testo da Mobile */
        .jodi-content { 
            padding-top: 22vh; 
            padding-left: 15px;
            padding-right: 15px;
            overflow: hidden;
        }
        
        /* Scritte ingrandite e sicure */
        .raw-text { 
            font-size: 14px; 
            line-height: 1.1; 
            white-space: pre-wrap; 
            word-break: break-all; 
        }
        
        .pin-container { 
            width: 90px; 
            height: 90px; 
            bottom: 20px; 
            right: 20px; 
        }
    }
</style>