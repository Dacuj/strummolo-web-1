<style is:global>
    /* --- RESET E BLOCCO TOTALE DELLO SCROLL --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        /* FONDAMENTALE: Riportiamo lo sfondo a nero */
        /* background-color: #000000;  */
        height: 100vh;
        width: 100vw;
        overflow: hidden; 
        overscroll-behavior: none; 
        
        font-family: 'Courier New', Courier, Fixedsys, Terminal, monospace;
        font-weight: bold;
        -webkit-font-smoothing: none;
        font-smooth: never;
        cursor: url('https://cur.cursors-4u.net/nature/nat-10/nat926.cur'), auto;
    }

    /* --- VIDEO BACKGROUND --- */
    .bg-video {
        position: fixed; 
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        object-fit: cover;
        /* Spostiamo il video ancora più indietro */
        z-index: -2; 
        pointer-events: none;
        /* IMPORTANTE: Riportiamo l'opacità a 1.0 (nessuna trasparenza) */
        opacity: 1.0; 
    }

    /* --- DARK OVERLAY (Il trucco per scurire) --- */
    /* Crea un velo scuro tra il video (-2) e il contenuto (+1) */
    body::after {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        /* Questo è un nero semi-trasparente */
        /* L'ultimo numero (0.6) è l'opacità del velo. 
           - 0.0 è trasparente.
           - 1.0 è nero totale.
           0.6 (60%) è un buon valore per scurire molto. */
        background-color: rgba(0, 0, 0, 0.6); 
        z-index: -1; /* Sta sopra il video ma sotto il testo */
        pointer-events: none;
    }

    /* --- IL RESTO DEL CSS RIMANE INVARIATO --- */

    /* --- HEADER (Desktop) --- */
    header {
