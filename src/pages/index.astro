<script>
    // drag & drop delle icone sul desktop + navigazione con effetto "clessidra"
    (function () {
        var THRESHOLD = 5;

        document.querySelectorAll('a.desktop-icon').forEach(function (icon) {
            var dragging = false, moved = false, justDragged = false;
            var startX = 0, startY = 0, baseLeft = 0, baseTop = 0;
            var posKey = 'iconpos:' + (icon.getAttribute('href') || '');

            function place(left, top) {
                var w = icon.offsetWidth, h = icon.offsetHeight;
                left = Math.max(0, Math.min(left, window.innerWidth - w));
                top = Math.max(0, Math.min(top, window.innerHeight - h));
                icon.style.left = left + 'px';
                icon.style.top = top + 'px';
                icon.style.right = 'auto';
                icon.style.bottom = 'auto';
            }

            try {
                var saved = JSON.parse(localStorage.getItem(posKey) || 'null');
                if (saved && typeof saved.left === 'number') place(saved.left, saved.top);
            } catch (e) {}

            icon.addEventListener('pointerdown', function (e) {
                if (e.button && e.button !== 0) return;
                dragging = true; moved = false;
                startX = e.clientX; startY = e.clientY;
                var r = icon.getBoundingClientRect();
                baseLeft = r.left; baseTop = r.top;
                try { icon.setPointerCapture(e.pointerId); } catch (err) {}
            });

            icon.addEventListener('pointermove', function (e) {
                if (!dragging) return;
                var dx = e.clientX - startX, dy = e.clientY - startY;
                if (!moved && (dx * dx + dy * dy) > THRESHOLD * THRESHOLD) {
                    moved = true;
                    icon.classList.add('dragging');
                }
                if (moved) place(baseLeft + dx, baseTop + dy);
            });

            function endDrag(e) {
                if (!dragging) return;
                dragging = false;
                try { icon.releasePointerCapture(e.pointerId); } catch (err) {}
                if (moved) {
                    justDragged = true;
                    icon.classList.remove('dragging');
                    try {
                        localStorage.setItem(posKey, JSON.stringify({
                            left: parseInt(icon.style.left, 10) || 0,
                            top: parseInt(icon.style.top, 10) || 0
                        }));
                    } catch (err) {}
                    window.setTimeout(function () { justDragged = false; }, 300);
                }
            }
            icon.addEventListener('pointerup', endDrag);
            icon.addEventListener('pointercancel', endDrag);

            icon.addEventListener('click', function (e) {
                if (justDragged) { justDragged = false; e.preventDefault(); return; }
                if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
                e.preventDefault();
                var href = icon.getAttribute('href');
                document.body.classList.add('busy');
                window.setTimeout(function () { window.location.href = href; }, 550);
            });
        });
    })();
</script>

<script>
    // selezione ad area (marquee): trascina col tasto sinistro sul desktop vuoto (solo mouse)
    (function () {
        var layer = document.querySelector('.icons');
        var box = document.querySelector('.marquee');
        if (!layer || !box) return;
        var icons = Array.prototype.slice.call(document.querySelectorAll('a.desktop-icon'));
        var selecting = false, sx = 0, sy = 0;

        function clearSel() { icons.forEach(function (i) { i.classList.remove('selected'); }); }

        layer.addEventListener('pointerdown', function (e) {
            if (e.pointerType && e.pointerType !== 'mouse') return;
            if (e.button && e.button !== 0) return;
            if (e.target.closest('.desktop-icon')) return;
            selecting = true;
            sx = e.clientX; sy = e.clientY;
            clearSel();
            box.style.left = sx + 'px';
            box.style.top = sy + 'px';
            box.style.width = '0px';
            box.style.height = '0px';
            box.hidden = false;
            try { layer.setPointerCapture(e.pointerId); } catch (err) {}
        });

        layer.addEventListener('pointermove', function (e) {
            if (!selecting) return;
            var left = Math.min(sx, e.clientX), top = Math.min(sy, e.clientY);
            var w = Math.abs(e.clientX - sx), h = Math.abs(e.clientY - sy);
            box.style.left = left + 'px';
            box.style.top = top + 'px';
            box.style.width = w + 'px';
            box.style.height = h + 'px';
            var r1 = left, t1 = top, r2 = left + w, b2 = top + h;
            icons.forEach(function (icon) {
                var r = icon.getBoundingClientRect();
                icon.classList.toggle('selected', !(r.right < r1 || r.left > r2 || r.bottom < t1 || r.top > b2));
            });
        });

        function endSelect(e) {
            if (!selecting) return;
            selecting = false;
            box.hidden = true;
            try { layer.releasePointerCapture(e.pointerId); } catch (err) {}
        }
        layer.addEventListener('pointerup', endSelect);
        layer.addEventListener('pointercancel', endSelect);
    })();
</script>

