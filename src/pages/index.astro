</a>

<main class="desktop">
    <!-- ICONE = foto in stile macOS (placeholder): sostituisci i 4 src con le tue foto -->
    <div class="icons">
        <a class="desktop-icon i-bacheka" href="/bacheka" data-nav draggable="false">
            <span class="ico-photo"><img src="/img/psq.webp" alt="" draggable="false"></span>
            <span class="label">Bacheka</span>
        </a>

        <a class="desktop-icon i-archive" href="/archive" data-nav draggable="false">
