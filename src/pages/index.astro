<style is:global>
    :root {
        /* SFONDO: per usare la foto dei manichini carica il file in public/img/
           e cambia SOLO questa riga, es. url('/img/desktop-bg.jpg') */
        --wallpaper: url('/img/046813d3-5fab-4125-990d-9e8da96e31df.jpg');

        --cur-arrow: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='24'%20height='24'%3E%3Cpath%20d='M2%202L2%2018L6.5%2013.5L9.5%2020L12%2019L9%2012.5L15%2012.5Z'%20fill='white'%20stroke='black'%20stroke-width='1.3'%20stroke-linejoin='round'/%3E%3C/svg%3E") 2 2;
        --cur-busy: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='24'%20height='24'%3E%3Cg%20stroke='black'%20stroke-width='1.4'%20stroke-linejoin='round'%3E%3Crect%20x='4.5'%20y='2'%20width='15'%20height='2.6'%20fill='white'/%3E%3Crect%20x='4.5'%20y='19.4'%20width='15'%20height='2.6'%20fill='white'/%3E%3Cpath%20d='M6%204.6L18%204.6L12%2012Z'%20fill='white'/%3E%3Cpath%20d='M12%2012L6%2019.4L18%2019.4Z'%20fill='white'/%3E%3C/g%3E%3Cpath%20d='M9.3%2017.6L14.7%2017.6L12%2013.9Z'%20fill='goldenrod'/%3E%3Crect%20x='11.4'%20y='11.5'%20width='1.2'%20height='5'%20fill='goldenrod'/%3E%3C/svg%3E") 12 12;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body { height: 100%; }

    body {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        overscroll-behavior: none;
        background: #0a3a6b;
        font-family: Tahoma, Verdana, Geneva, sans-serif;
        cursor: var(--cur-arrow), auto;
    }

    body.busy,
    body.busy * { cursor: var(--cur-busy), wait !important; }

    .desktop {
        position: fixed;
        inset: 0;
        background-image: var(--wallpaper);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .icons { position: absolute; inset: 0; }

    .desktop-icon {
        position: absolute;
        width: 88px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        padding: 6px 4px;
        text-decoration: none;
        text-align: center;
        border: 1px solid transparent;
        cursor: var(--cur-arrow), auto;
        -webkit-user-select: none;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
    }

    .desktop-icon .ico {
        width: 48px;
        height: 48px;
        filter: drop-shadow(1px 1px 1px rgba(0, 0, 0, 0.55));
    }

    .desktop-icon .label {
        font-size: 13px;
        line-height: 1.15;
        color: #fff;
        padding: 1px 4px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95), 0 0 2px rgba(0, 0, 0, 0.85);
    }

    .desktop-icon:hover,
    .desktop-icon:focus {
        outline: none;
        background: rgba(11, 100, 194, 0.30);
        border: 1px dotted rgba(255, 255, 255, 0.75);
    }

    .desktop-icon:hover .label,
    .desktop-icon:focus .label {
        background: #0a64c2;
        text-shadow: none;
    }

    .desktop-icon:active { cursor: var(--cur-busy), wait; }

    /* posizioni sparse (desktop) */
    .i-bacheka { top: 10%; left: 9%;  }
    .i-archive { top: 20%; left: 70%; }
    .i-more    { top: 64%; left: 18%; }
    .i-shop    { top: 72%; left: 58%; }

    /* mobile: stessa vibe, icone in griglia centrata */
    @media (max-width: 768px) {
        .desktop {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .icons {
            position: relative;
            inset: auto;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 22px 12px;
            width: min(86vw, 360px);
            padding: 16px;
        }

        .desktop-icon {
            position: static;
            width: auto;
        }

        .desktop-icon .ico {
            width: 44px;
            height: 44px;
        }
    }
</style>
