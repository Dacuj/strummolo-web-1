                <rect x="9" y="5" width="30" height="38" rx="2" fill="#fdfdf2" stroke="#222" stroke-width="2"/>
                <rect x="9" y="5" width="30" height="8" fill="#3a6ea5" stroke="#222" stroke-width="2"/>
                <line x1="14" y1="20" x2="34" y2="20" stroke="#9aa3ad" stroke-width="2"/>
                <line x1="14" y1="26" x2="34" y2="26" stroke="#9aa3ad" stroke-width="2"/>
                <line x1="14" y1="32" x2="34" y2="32" stroke="#9aa3ad" stroke-width="2"/>
