        </a>

        <a class="desktop-icon i-more" href="/more" data-nav draggable="false">
            <svg class="ico" viewBox="0 0 48 48" aria-hidden="true">
                <path d="M5 13 h14 l4 4 h20 v22 a2 2 0 0 1 -2 2 h-34 a2 2 0 0 1 -2 -2 z" fill="#e0a92e" stroke="#6d4f12" stroke-width="2" stroke-linejoin="round"/>
                <path d="M5 19 h38 v18 a2 2 0 0 1 -2 2 h-34 a2 2 0 0 1 -2 -2 z" fill="#ffd166" stroke="#6d4f12" stroke-width="2" stroke-linejoin="round"/>
            </svg>
