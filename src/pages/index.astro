<!-- THREE.JS WIREFRAME RETRO BACKGROUND -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js" is:inline></script>
<script is:inline>
    (function () {
        const canvas = document.getElementById('bg-canvas');
        if (!canvas || typeof THREE === 'undefined') return;

        const scena = new THREE.Scene();
        scena.fog = new THREE.FogExp2(0x000000, 0.025);

        const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(0, 8, 40);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ canvas: canvas, antialias: false });
        const scalaPixel = 4;
        renderer.setSize(window.innerWidth / scalaPixel, window.innerHeight / scalaPixel, false);

        const larghezza = 200;
        const altezza = 200;
        const segmenti = 35;

        const geometria = new THREE.PlaneGeometry(larghezza, altezza, segmenti, segmenti);
        const materiale = new THREE.MeshBasicMaterial({ color: 0xff0000, wireframe: true });
        const terreno = new THREE.Mesh(geometria, materiale);
        terreno.rotation.x = -Math.PI / 2;
        scena.add(terreno);

        const clock = new THREE.Clock();
        let ultimoTempo = 0;
        const fpsDesiderati = 12;
        const intervalloFrame = 1 / fpsDesiderati;

        function anima() {
            requestAnimationFrame(anima);
            const tempo = clock.getElapsedTime();
            const delta = tempo - ultimoTempo;

            if (delta > intervalloFrame) {
                ultimoTempo = tempo - (delta % intervalloFrame);
                const posizioni = geometria.attributes.position;

                for (let i = 0; i < posizioni.count; i++) {
                    const x = posizioni.getX(i);
                    const y = posizioni.getY(i);
                    const movimentoY = y + tempo * 25;
                    let z = Math.sin(x * 0.15) * Math.cos(movimentoY * 0.1) * 18;
                    if (z < 4) z = 0;
                    posizioni.setZ(i, z);
                }

                posizioni.needsUpdate = true;
                renderer.render(scena, camera);
            }
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth / scalaPixel, window.innerHeight / scalaPixel, false);
        });

        anima();
    })();
</script>
