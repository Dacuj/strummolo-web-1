            <span class="label">Shop</span>
        </a>
    </div>
</main>

<script>
    // navigazione con effetto "clessidra" (loading) ispirato al vecchio desktop
    document.querySelectorAll('a[data-nav]').forEach(function (a) {
        a.addEventListener('click', function (e) {
            if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
            e.preventDefault();
            var href = a.getAttribute('href');
            document.body.classList.add('busy');
            window.setTimeout(function () { window.location.href = href; }, 550);
        });
    });
</script>

<script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
</script>
</body>
</html>

<style is:global>
    :root {
        /* SFONDO del desktop (foto manichini) */
        --wallpaper: url('/img/desktop.jpg');

        --cur-arrow: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='32'%20height='32'%20viewBox='0%200%2024%2024'%3E%3Cpath%20d='M2%202L2%2018L6.5%2013.5L9.5%2020L12%2019L9%2012.5L15%2012.5Z'%20fill='white'%20stroke='black'%20stroke-width='1.3'%20stroke-linejoin='round'/%3E%3C/svg%3E") 3 3;
        --cur-busy: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='32'%20height='32'%20viewBox='0%200%2024%2024'%3E%3Cg%20stroke='black'%20stroke-width='1.4'%20stroke-linejoin='round'%3E%3Crect%20x='4.5'%20y='2'%20width='15'%20height='2.6'%20fill='white'/%3E%3Crect%20x='4.5'%20y='19.4'%20width='15'%20height='2.6'%20fill='white'/%3E%3Cpath%20d='M6%204.6L18%204.6L12%2012Z'%20fill='white'/%3E%3Cpath%20d='M12%2012L6%2019.4L18%2019.4Z'%20fill='white'/%3E%3C/g%3E%3Cpath%20d='M9.3%2017.6L14.7%2017.6L12%2013.9Z'%20fill='goldenrod'/%3E%3Crect%20x='11.4'%20y='11.5'%20width='1.2'%20height='5'%20fill='goldenrod'/%3E%3C/svg%3E") 16 16;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html, body { height: 100%; }

    body {
        width: 100vw;
        height: 100vh;
        overflow: hidden;
        overscroll-behavior: none;
        background: #0a3a6b;
        font-family: Tahoma, Verdana, Geneva, sans-serif;
        cursor: var(--cur-arrow), auto;
    }

    body.busy,
    body.busy * { cursor: var(--cur-busy), wait !important; }

    .desktop {
        position: fixed;
        inset: 0;
        background-image: var(--wallpaper);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* logo strummolo123, mantenuto ma centrato in alto */
    .logo {
        position: fixed;
        top: 14px;
        left: 50%;
        transform: translateX(-50%) rotate(-1deg);
        z-index: 1500;
        display: flex;
        gap: 2px;
        padding: 9px 11px;
        background: rgba(0, 0, 0, 0.8);
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        text-decoration: none;
        text-shadow: 2px 2px 0 #000;
        cursor: var(--cur-arrow), auto;
    }

    .logo span { color: #fff; }
    .logo span:nth-child(1) { color: #ea4335; }
    .logo span:nth-child(2) { color: #fbbc05; }
    .logo span:nth-child(3) { color: #4285f4; }
    .logo span:nth-child(4) { color: #34a853; }
    .logo span:nth-child(5) { color: #ea4335; }
    .logo .arrows { color: #4285f4; margin-left: 5px; }
    .logo:hover { opacity: 0.85; }

    .icons { position: absolute; inset: 0; }

    .desktop-icon {
        position: absolute;
        width: 168px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        padding: 6px 4px;
        text-decoration: none;
        text-align: center;
        cursor: var(--cur-arrow), auto;
        -webkit-user-select: none;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
    }

    /* tile foto stile vecchio macOS (Aqua): angoli arrotondati, lucentezza, ombra */
    .ico-photo {
        position: relative;
        display: block;
        width: 150px;
        height: 150px;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 12px 20px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(0, 0, 0, 0.35);
        transition: transform 0.12s ease, box-shadow 0.12s ease;
    }

    .ico-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .ico-photo::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: linear-gradient(to bottom, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.14) 38%, rgba(255, 255, 255, 0) 52%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
        pointer-events: none;
    }

    .desktop-icon .label {
        font-size: 18px;
        line-height: 1.15;
        color: #fff;
        padding: 2px 6px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95), 0 0 2px rgba(0, 0, 0, 0.85);
    }

    .desktop-icon:hover,
    .desktop-icon:focus { outline: none; }

    .desktop-icon:hover .ico-photo,
    .desktop-icon:focus .ico-photo {
        transform: scale(1.05);
        box-shadow: 0 16px 26px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(0, 0, 0, 0.35);
    }

    .desktop-icon:hover .label,
    .desktop-icon:focus .label {
        background: rgba(0, 0, 0, 0.6);
        border-radius: 6px;
        text-shadow: none;
    }

    .desktop-icon:active { cursor: var(--cur-busy), wait; }

    /* posizioni sparse (desktop): grandi tile agli angoli, volto centrale visibile */
    .i-bacheka { top: 8%;  left: 5%;  }
    .i-archive { top: 8%;  left: 66%; }
    .i-more    { top: 55%; left: 7%;  }
    .i-shop    { top: 55%; left: 66%; }

    /* mobile: stessa vibe, icone sparse in modo asimmetrico (no griglia) */
    @media (max-width: 768px) {
        .logo { font-size: 0.6rem; top: 10px; padding: 7px 9px; }

        .desktop-icon { width: 116px; }

        .ico-photo {
            width: 104px;
            height: 104px;
            border-radius: 20px;
        }

        .desktop-icon .label { font-size: 15px; }

        .i-bacheka { top: 8%;  left: 5%;  }
        .i-archive { top: 27%; left: 45%; }
        .i-more    { top: 51%; left: 8%;  }
        .i-shop    { top: 71%; left: 47%; }
    }
</style>
