<body>

<main class="desktop">
    <div class="icons">
        <a class="desktop-icon i-bacheka" href="/bacheka" data-nav draggable="false">
            <svg class="ico" viewBox="0 0 48 48" aria-hidden="true">
                <rect x="7" y="9" width="34" height="24" rx="4" fill="#ffffff" stroke="#222" stroke-width="2"/>
                <path d="M16 33 v7 l9 -7 z" fill="#ffffff" stroke="#222" stroke-width="2" stroke-linejoin="round"/>
                <circle cx="17" cy="21" r="2.3" fill="#222"/>
                <circle cx="24" cy="21" r="2.3" fill="#222"/>
                <circle cx="31" cy="21" r="2.3" fill="#222"/>
            </svg>
            <span class="label">Bacheka</span>
        </a>

        <a class="desktop-icon i-archive" href="/archive" data-nav draggable="false">
