    .i-archive { top: 20%; left: 70%; }
    .i-more    { top: 64%; left: 18%; }
    .i-shop    { top: 72%; left: 58%; }

    /* mobile: stessa vibe, icone sparse in modo asimmetrico (no griglia) */
    @media (max-width: 768px) {
