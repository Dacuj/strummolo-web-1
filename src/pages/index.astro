        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.95), 0 0 2px rgba(0, 0, 0, 0.85);
    }

    .desktop-icon:hover,
    .desktop-icon:focus {
        outline: none;
        background: rgba(11, 100, 194, 0.30);
        border: 1px dotted rgba(255, 255, 255, 0.75);
    }

    .desktop-icon:hover .label,
    .desktop-icon:focus .label {
        background: #0a64c2;
        text-shadow: none;
    }

    .desktop-icon:active { cursor: var(--cur-busy), wait; }

    /* posizioni sparse (desktop) */
