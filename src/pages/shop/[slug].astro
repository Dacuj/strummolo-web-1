---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('prodotti');
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

interface Props {
  product: CollectionEntry<'prodotti'>;
}

const { product } = Astro.props;
const { title, description, price, images } = product.data;
const INSTAGRAM_HANDLE = 'strummolo123';
const INSTAGRAM_URL = `https://instagram.com/${INSTAGRAM_HANDLE}`;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} // Strummolo Shop</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="product" />
    {images && images[0] && <meta property="og:image" content={images[0]} />}
  </head>
  <body>

    <a href="/shop" class="back" aria-label="Torna allo shop">← shop</a>

    <main class="pdp">
      <h1 class="pdp-title">{title}</h1>
      {price && <p class="pdp-price">{price}</p>}

      <div class="pdp-gallery">
        {images.map((src, i) => (
          <img
            class="pdp-img"
            src={src}
            alt={`${title} — foto ${i + 1}`}
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        ))}
      </div>

      {description && <p class="pdp-desc">{description}</p>}

      <div class="pdp-info">
        <p>
          <strong>Random single stitch.</strong> Ogni capo è una maglietta single stitch
          vintage, di un colore sempre diverso: non esistono due pezzi uguali. La stampa
          originale della maglietta viene preservata — la nostra stampa viene applicata
          all'interno, <em>inside out</em>.
        </p>
        <p class="pdp-note">
          Questo non è un vero negozio, è solo uno showcase: dal sito non si ordina.
          Se vuoi organizzare una spedizione, scrivici in DM su
          <a class="pdp-link" href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">Instagram @{INSTAGRAM_HANDLE}</a>.
        </p>
      </div>
    </main>

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      ::selection { background: #fff; color: #000; }

      html, body { height: 100%; }

      body {
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        color: #fff;
        background-color: #000;
        overflow-x: hidden;
      }

      a { color: inherit; text-decoration: none; }

      .back {
        position: fixed;
        top: 14px;
        left: 16px;
        z-index: 10;
        font-size: 13px;
        letter-spacing: 1px;
        opacity: 0.7;
        transition: opacity 0.15s;
      }
      .back:hover { opacity: 1; text-decoration: underline; }

      .pdp {
        width: 100%;
        max-width: 620px;
        margin: 0 auto;
        padding: 64px 20px 100px;
      }

      .pdp-title {
        text-align: center;
        font-size: 38px;
        font-weight: 700;
        line-height: 1.1;
        word-break: break-word;
      }

      .pdp-price {
        text-align: center;
        margin-top: 10px;
        font-size: 15px;
        letter-spacing: 2px;
        opacity: 0.8;
      }

      .pdp-gallery {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 28px;
        margin: 36px 0;
      }

      .pdp-img {
        display: block;
        max-width: 100%;
        max-height: 80vh;
        width: auto;
        height: auto;
      }

      .pdp-desc {
        text-align: center;
        font-size: 15px;
        line-height: 1.6;
        opacity: 0.85;
        margin-bottom: 28px;
      }

      .pdp-info {
        max-width: 520px;
        margin: 0 auto;
        text-align: center;
        font-size: 15px;
        line-height: 1.7;
      }
      .pdp-info p + p { margin-top: 18px; }
      .pdp-info strong { font-weight: 700; }
      .pdp-info em { font-style: italic; }

      .pdp-note { opacity: 0.85; }

      .pdp-link {
        text-decoration: underline;
        text-underline-offset: 3px;
        white-space: nowrap;
        transition: opacity 0.15s;
      }
      .pdp-link:hover { opacity: 0.7; }

      @media (max-width: 480px) {
        .pdp { padding: 56px 16px 80px; }
        .pdp-title { font-size: 30px; }
        .pdp-gallery { gap: 20px; }
      }
    </style>
  </body>
</html>
