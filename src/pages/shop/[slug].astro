---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('prodotti');
  return products.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
}

interface Props {
  product: CollectionEntry<'prodotti'>;
}

const { product } = Astro.props;
const { title, description, images } = product.data;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} // Strummolo Shop</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="product" />
    {images && images[0] && <meta property="og:image" content={images[0]} />}
  </head>
  <body>

    <a href="/shop" class="wip-back" aria-label="Torna allo shop">← shop</a>

    <main class="wip-main">
      <p class="wip-title">{title}</p>
      <h1 class="wip-text">Work in progress</h1>
    </main>

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      ::selection { background: #fff; color: #000; }

      html, body { height: 100%; }

      body {
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        color: #fff;
        background-color: #000;
        overflow-x: hidden;
      }

      a { color: inherit; text-decoration: none; }

      .wip-back {
        position: fixed;
        top: 14px;
        left: 16px;
        z-index: 10;
        font-size: 13px;
        letter-spacing: 1px;
        opacity: 0.7;
        transition: opacity 0.15s;
      }
      .wip-back:hover { opacity: 1; text-decoration: underline; }

      .wip-main {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px 20px;
      }

      .wip-title {
        font-size: 14px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.6;
        margin-bottom: 14px;
      }

      .wip-text {
        font-size: 34px;
        font-weight: 700;
        letter-spacing: 1px;
      }
    </style>
  </body>
</html>
