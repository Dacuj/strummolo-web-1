---
import { getCollection } from 'astro:content';

const products = (await getCollection('prodotti', ({ data }) => data.available !== false))
  .sort((a, b) => (a.data.order ?? Infinity) - (b.data.order ?? Infinity));
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop // Strummolo</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content="Strummolo shop — per ordinare scrivici su Instagram @strummolo123." />
  </head>
  <body>

    <a href="/" class="shop-back" aria-label="Torna alla home">← strummolo</a>

    <main class="shop-col">
      {products.length === 0 ? (
        <div class="shop-empty">
          <p>Nessun prodotto in stock — torna presto.</p>
        </div>
      ) : (
        products.map((p) => (
          <section class="outfit">
            <h2 class="outfit-title">{p.data.title}</h2>

            {p.data.head && (
              <img class="piece" src={p.data.head} alt="" loading="lazy" />
            )}

            <a
              class="piece-link"
              href={`/shop/${p.slug}`}
              aria-label={`Apri ${p.data.title}`}
            >
              <img class="piece" src={p.data.images[0]} alt={p.data.title} loading="lazy" />
            </a>

            {p.data.bottom && (
              <img class="piece" src={p.data.bottom} alt="" loading="lazy" />
            )}
          </section>
        ))
      )}
    </main>

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      ::selection { background: #fff; color: #000; }

      html, body { height: 100%; }

      body {
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        color: #fff;
        background-color: #000;
        overflow-x: hidden;
      }

      a { color: inherit; text-decoration: none; }

      /* ===== LINK HOME (discreto, fisso) ===== */
      .shop-back {
        position: fixed;
        top: 14px;
        left: 16px;
        z-index: 10;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 13px;
        letter-spacing: 1px;
        opacity: 0.7;
        transition: opacity 0.15s;
      }
      .shop-back:hover { opacity: 1; text-decoration: underline; }

      /* ===== COLONNA "MOBILE" CENTRATA ===== */
      .shop-col {
        width: 100%;
        max-width: 440px;
        margin: 0 auto;
        background: #000;
        padding-top: 8px;
        padding-bottom: 64px;
      }

      /* ===== OUTFIT (un prodotto = un corpo) ===== */
      .outfit {
        padding: 28px 0 56px;
      }

      .outfit-title {
        text-align: center;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.1;
        margin: 0 0 18px;
        padding: 0 12px;
        word-break: break-word;
      }

      /* I pezzi si impilano a filo per comporre il corpo.
         Niente filtri: lo sfondo nero gestisce i PNG trasparenti. */
      .piece {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 0 auto;
      }

      .piece-link {
        display: block;
        transition: filter 0.2s ease;
      }
      .piece-link:hover {
        filter: drop-shadow(0 0 16px rgba(255, 255, 255, 0.25));
      }

      /* ===== STATO VUOTO ===== */
      .shop-empty {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px 20px;
        opacity: 0.75;
        font-size: 16px;
        letter-spacing: 1px;
      }
    </style>
  </body>
</html>
