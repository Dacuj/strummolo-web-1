---
import { getCollection } from 'astro:content';

const products = await getCollection('prodotti', ({ data }) => data.available !== false);
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop // Strummolo</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content="Strummolo shop — per ordinare scrivici su Instagram @strummolo123." />
  </head>
  <body>

    <header class="shop-header">
      <a href="/" class="shop-back">← strummolo</a>
      <span class="shop-title">SHOP</span>
      <span class="shop-spacer"></span>
    </header>

    <main class="shop-main">
      {products.length === 0 ? (
        <div class="shop-empty">
          <p>Nessun prodotto in stock — torna presto.</p>
        </div>
      ) : (
        <ul class="shop-grid">
          {products.map((p) => (
            <li class="shop-item">
              <a href={`/shop/${p.slug}`} class="shop-link" aria-label={`Apri ${p.data.title}`}>
                <div class="shop-imgwrap">
                  <img class="shop-img" src={p.data.images[0]} alt={p.data.title} loading="lazy" />
                </div>
                <span class="shop-name">{p.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      ::selection { background: #fff; color: #000; }

      html, body { height: 100%; }

      body {
        min-height: 100vh;
        font-family: "Courier New", Courier, monospace;
        color: #fff;
        background-color: #000;
        background-image: url('/img/mir.webp');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        position: relative;
        overflow-x: hidden;
      }

      /* Overlay scuro per leggibilità — quando avrai la foto definitiva basta
         alzare/abbassare l'opacità qui sotto */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        z-index: 0;
        pointer-events: none;
      }

      a { color: inherit; text-decoration: none; }

      /* ===== HEADER ===== */
      .shop-header {
        position: relative;
        z-index: 1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 32px;
        font-size: 13px;
        letter-spacing: 2px;
        text-transform: uppercase;
      }

      .shop-back {
        opacity: 0.85;
        transition: opacity 0.15s;
      }
      .shop-back:hover { opacity: 1; text-decoration: underline; }

      .shop-title {
        font-weight: bold;
        letter-spacing: 4px;
      }

      .shop-spacer { width: 90px; } /* bilancia il link a sinistra */

      /* ===== MAIN ===== */
      .shop-main {
        position: relative;
        z-index: 1;
        padding: 60px 32px 120px 32px;
        min-height: calc(100vh - 80px);
      }

      /* ===== GRID ===== */
      .shop-grid {
        list-style: none;
        max-width: 1200px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 80px 60px;
        justify-items: center;
      }

      .shop-item {
        width: 100%;
        max-width: 300px;
      }

      .shop-link {
        display: block;
        text-align: center;
      }

      .shop-imgwrap {
        width: 100%;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: visible;
      }

      .shop-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        /* I PNG devono essere puliti: niente filtri, niente bordi */
        transition: transform 0.25s ease, filter 0.25s ease;
      }

      .shop-link:hover .shop-img {
        transform: scale(1.05);
        filter: drop-shadow(0 6px 20px rgba(255, 255, 255, 0.2));
      }

      .shop-name {
        display: inline-block;
        margin-top: 18px;
        font-family: "Courier New", monospace;
        font-size: 13px;
        letter-spacing: 2px;
        color: #fff;
        text-transform: uppercase;
        opacity: 0.85;
      }

      .shop-link:hover .shop-name {
        opacity: 1;
        text-decoration: underline;
      }

      /* ===== EMPTY ===== */
      .shop-empty {
        text-align: center;
        padding: 120px 20px;
        opacity: 0.75;
        font-size: 16px;
        letter-spacing: 1px;
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        .shop-header { padding: 16px 18px; font-size: 11px; letter-spacing: 1px; }
        .shop-title { letter-spacing: 3px; }
        .shop-spacer { width: 60px; }
        .shop-main { padding: 30px 16px 80px 16px; }
        .shop-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 40px 20px;
        }
        .shop-item { max-width: 100%; }
        .shop-name { font-size: 11px; letter-spacing: 1.5px; margin-top: 12px; }
      }

      @media (max-width: 400px) {
        .shop-grid { grid-template-columns: 1fr; gap: 50px; }
      }
    </style>
  </body>
</html>
