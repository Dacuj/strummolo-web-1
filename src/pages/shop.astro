---
import { getCollection } from 'astro:content';

const products = await getCollection('prodotti', ({ data }) => data.available !== false);

const now = new Date();
const sysDate = now.toISOString().replace('T', ' // ').substring(0, 19);

// Layout schematic — griglia deterministica
const COLS = 3;
const cellW = 340;
const cellH = 300;
const padX = 60;
const padY = 80;
const totalRows = Math.max(1, Math.ceil(products.length / COLS));
const canvasWidth = padX * 2 + COLS * cellW;
const canvasHeight = padY * 2 + totalRows * cellH + 40;

// Readout finti seedati dallo slug (no random => stabili tra build)
const code = (s: string, i: number) => (s.charCodeAt(i % s.length) || 65);
const nodes = products.map((p, i) => {
  const col = i % COLS;
  const row = Math.floor(i / COLS);
  const slug = p.slug || `prod${i}`;
  return {
    product: p,
    slug,
    x: padX + col * cellW,
    y: padY + row * cellH,
    col, row,
    rpm:  ((code(slug, 0) % 9) + 0.1).toFixed(1),
    gpm:  1500 + (code(slug, 1) % 400),
    ft:   20 + (code(slug, 2) % 25),
    load: 30 + (code(slug, 3) % 50),
    open: 20 + (code(slug, 4) % 70),
  };
});

// Pipe a gomito tra nodi consecutivi (i, i+1)
const pipes = [];
for (let i = 0; i < nodes.length - 1; i++) {
  const a = nodes[i];
  const b = nodes[i + 1];
  const x1 = a.x + cellW * 0.5;
  const y1 = a.y + cellH * 0.5;
  const x2 = b.x + cellW * 0.5;
  const y2 = b.y + cellH * 0.5;
  const midX = (x1 + x2) / 2;
  pipes.push({
    d: `M ${x1} ${y1} L ${midX} ${y1} L ${midX} ${y2} L ${x2} ${y2}`,
    elbows: [{ x: midX, y: y1 }, { x: midX, y: y2 }],
    label: { x: midX + 8, y: (y1 + y2) / 2 - 6 },
  });
}

const INSTAGRAM_URL = 'https://instagram.com/strummolo';
const EMAIL = 'ciao@strummolo.com';

// Top menu — ognuno con colore distinto come nei DCS reali
const topMenu = [
  { label: 'Sys',     href: '/',        color: '#ffff00' },
  { label: 'Alarm',   href: '#',        color: '#ff0000' },
  { label: 'Report',  href: '/archive', color: '#00ffff' },
  { label: 'N2Disp',  href: '/bacheka', color: '#ffff00' },
  { label: 'P_Sum',   href: '#',        color: '#00ffff' },
  { label: 'M_Strt',  href: '#',        color: '#ffff00' },
  { label: 'Trends',  href: '/archive', color: '#00ffff' },
  { label: 'Trng',    href: '#',        color: '#ffff00' },
  { label: 'PrtScr',  href: '#',        color: '#00ffff' },
  { label: 'ABB',     href: '/about',   color: '#ffff00' },
];

const fnKeys = [
  { label: 'ALM ACK',   action: 'alarm',  color: '#cccccc' },
  { label: 'A/M',       action: '',       color: '#cccccc' },
  { label: 'R/L',       action: '',       color: '#cccccc' },
  { label: '▲',         action: 'up',     color: '#cccccc' },
  { label: '▼',         action: 'down',   color: '#cccccc' },
  { label: 'HELP',      action: 'help',   color: '#cccccc' },
  { label: 'START',     action: 'start',  color: '#00ff00' },
  { label: 'STOP',      action: 'stop',   color: '#ffffff' },
  { label: 'TREND',     action: 'trend',  color: '#cccccc' },
  { label: 'PREV DISP', action: 'back',   color: '#cccccc' },
];
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop // Strummolo DCS</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content="Strummolo shop — pezzi unici, DM su Instagram o email per acquisto." />
  </head>
  <body>

    <!-- ===== TOP SCADA MENU BAR ===== -->
    <nav class="scada-topbar" aria-label="System menu">
      {topMenu.map((m) => (
        <a class="topbar-btn" href={m.href} style={`background:${m.color}`}>{m.label}</a>
      ))}
    </nav>

    <!-- ===== TITLE BAR ===== -->
    <header class="title-bar">
      <h1 class="title-name">STRUMMOLO PRODUCT GRID</h1>
      <span class="title-ack">PAGE ACK</span>
      <span class="title-sys">{sysDate}</span>
    </header>

    <!-- ===== INTRO TERMINAL ===== -->
    <section class="intro-block">
      <p>
        &gt; PROCESS NODES BELOW REPRESENT AVAILABLE INVENTORY. EACH NODE STREAMS LIVE READOUTS (RPM / GPM / FT / %LOAD).
        TO PURCHASE A UNIT, CONTACT VIA INSTAGRAM DM OR EMAIL. NO ONLINE CHECKOUT. STOCK IS FINITE.
      </p>
    </section>

    {products.length === 0 ? (
      <!-- ===== EMPTY STATE ===== -->
      <div class="empty-state">
        <div class="empty-frame">
          <div class="empty-title">!! NO PROCESS NODES ONLINE !!</div>
          <div class="empty-sub">AWAITING SIGNAL FROM CONTROL PANEL...</div>
          <div class="empty-blink">█</div>
        </div>
      </div>
    ) : (
      <!-- ===== SCHEMATIC CANVAS ===== -->
      <main class="schematic-wrap">
        <div
          class="schematic"
          style={`width:${canvasWidth}px;height:${canvasHeight}px;`}
        >
          <!-- Tubi SVG dietro ai nodi -->
          <svg
            class="pipes"
            viewBox={`0 0 ${canvasWidth} ${canvasHeight}`}
            preserveAspectRatio="xMidYMid meet"
            aria-hidden="true"
          >
            {pipes.map((pipe, i) => (
              <g class="pipe-group">
                <path d={pipe.d} class="pipe-line" />
                {pipe.elbows.map((e) => (
                  <circle cx={e.x} cy={e.y} r="5" class="pipe-valve" />
                ))}
                <text x={pipe.label.x} y={pipe.label.y} class="pipe-label">FLOW {i + 1} →</text>
              </g>
            ))}
          </svg>

          <!-- Nodi prodotto -->
          {nodes.map((n) => (
            <article
              class="ics-node"
              style={`left:${n.x}px;top:${n.y}px;width:${cellW - 30}px;`}
              data-images={JSON.stringify(n.product.data.images)}
              data-title={n.product.data.title}
              data-desc={n.product.data.description}
              data-price={n.product.data.price}
              tabindex="0"
              role="button"
              aria-label={`Apri dettagli ${n.product.data.title}`}
            >
              <header class="node-hdr">
                <span class="node-tag">NODE_{String(n.col + 1).padStart(2, '0')}</span>
                <span class="node-name">{n.product.data.title.toUpperCase()}</span>
              </header>

              <div class="node-readouts">
                <span class="rd-rpm">{n.rpm} <em>RPM</em></span>
                <span class="rd-gpm">{n.gpm} <em>GPM</em></span>
                <span class="rd-ft">{n.ft}.0 <em>FT</em></span>
              </div>

              <div class="node-imgwrap">
                <img class="node-thumb" src={n.product.data.images[0]} alt={n.product.data.title} loading="lazy" />
                <span class="node-open">{n.open}<em> %OPEN</em></span>
              </div>

              <div class="node-load">
                <span>% LOAD: {n.load}</span>
                <span class="load-bar" aria-hidden="true">
                  {'▮'.repeat(Math.round(n.load / 20))}{'▯'.repeat(5 - Math.round(n.load / 20))}
                </span>
              </div>

              <footer class="node-foot">
                <span class="node-price">{n.product.data.price}</span>
                <span class="node-cta">[ CLICK TO INSPECT ]</span>
              </footer>
            </article>
          ))}
        </div>
      </main>
    )}

    <!-- ===== BOTTOM FUNCTION KEY BAR ===== -->
    <nav class="fn-bar" aria-label="Function keys">
      {fnKeys.map((k) => (
        <button class="fn-key" data-action={k.action} style={`color:${k.color}`}>{k.label}</button>
      ))}
    </nav>

    <!-- ===== MODALE GALLERIA ===== -->
    <div id="imageModal" class="modal" aria-hidden="true">
      <span class="close-btn" id="closeModal" role="button" aria-label="Chiudi">&times;</span>

      <div class="modal-content-wrapper">
        <button id="prevBtn" class="nav-btn" style="display:none;" aria-label="Precedente">&lt;</button>

        <div class="modal-inner">
          <img class="modal-img" id="expandedImg" src="" alt="Prodotto ingrandito" />
          <div class="modal-info">
            <h2 class="modal-title" id="modalTitle"></h2>
            <div class="modal-readouts">
              <span class="mod-r1">STATUS: ONLINE</span>
              <span class="mod-r2" id="modalPrice"></span>
            </div>
            <p class="modal-desc" id="modalDesc"></p>
            <div class="modal-cta-row">
              <a class="modal-cta cta-ig" href={INSTAGRAM_URL} target="_blank" rel="noopener noreferrer">DM ON INSTAGRAM</a>
              <a class="modal-cta cta-mail" href={`mailto:${EMAIL}`}>EMAIL US</a>
            </div>
            <div class="modal-hint">&gt; CONTACT TO REQUEST UNIT. NO ONLINE CHECKOUT.</div>
          </div>
        </div>

        <button id="nextBtn" class="nav-btn" style="display:none;" aria-label="Successivo">&gt;</button>
      </div>

      <div class="nav-controls" id="mobileControls" style="display:none;"></div>
    </div>

    <script>
      const modal = document.getElementById('imageModal');
      const expandedImg = document.getElementById('expandedImg');
      const modalTitle = document.getElementById('modalTitle');
      const modalDesc = document.getElementById('modalDesc');
      const modalPrice = document.getElementById('modalPrice');
      const closeModal = document.getElementById('closeModal');
      const prevBtn = document.getElementById('prevBtn');
      const nextBtn = document.getElementById('nextBtn');
      const mobileControls = document.getElementById('mobileControls');

      let currentImages = [];
      let currentIndex = 0;

      function openNode(node) {
        const raw = node.getAttribute('data-images');
        try {
          currentImages = JSON.parse(raw || '[]');
        } catch (e) {
          currentImages = [];
        }
        if (currentImages.length === 0) return;
        currentIndex = 0;
        modalTitle.textContent = node.getAttribute('data-title') || '';
        modalDesc.textContent = node.getAttribute('data-desc') || '';
        modalPrice.textContent = 'PRICE: ' + (node.getAttribute('data-price') || '---');
        updateModalView();
        modal.classList.add('active');
        modal.setAttribute('aria-hidden', 'false');
      }

      function updateModalView() {
        expandedImg.src = currentImages[currentIndex];
        const isMultiple = currentImages.length > 1;
        if (window.innerWidth > 768) {
          prevBtn.style.display = isMultiple ? 'block' : 'none';
          nextBtn.style.display = isMultiple ? 'block' : 'none';
          mobileControls.style.display = 'none';
        } else {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
          if (isMultiple) {
            mobileControls.style.display = 'flex';
            if (!mobileControls.contains(prevBtn)) mobileControls.appendChild(prevBtn);
            if (!mobileControls.contains(nextBtn)) mobileControls.appendChild(nextBtn);
            prevBtn.style.display = 'block';
            nextBtn.style.display = 'block';
          }
        }
      }

      document.querySelectorAll('.ics-node').forEach((node) => {
        node.addEventListener('click', () => openNode(node));
        node.addEventListener('keydown', (ev) => {
          if (ev.key === 'Enter' || ev.key === ' ') {
            ev.preventDefault();
            openNode(node);
          }
        });
      });

      if (nextBtn) {
        nextBtn.onclick = (e) => {
          e.stopPropagation();
          currentIndex = (currentIndex + 1) % currentImages.length;
          updateModalView();
        };
      }
      if (prevBtn) {
        prevBtn.onclick = (e) => {
          e.stopPropagation();
          currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
          updateModalView();
        };
      }

      function closeModalFn() {
        modal.classList.remove('active');
        modal.setAttribute('aria-hidden', 'true');
      }

      if (closeModal) closeModal.onclick = closeModalFn;
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModalFn();
      });
      document.addEventListener('keydown', (e) => {
        if (!modal.classList.contains('active')) return;
        if (e.key === 'Escape') closeModalFn();
        if (e.key === 'ArrowRight' && nextBtn && nextBtn.style.display !== 'none') nextBtn.click();
        if (e.key === 'ArrowLeft' && prevBtn && prevBtn.style.display !== 'none') prevBtn.click();
      });

      // Bottom function keys decorativi
      document.querySelectorAll('.fn-key').forEach((b) => {
        b.addEventListener('click', () => {
          const a = b.getAttribute('data-action');
          if (a === 'back') history.back();
          else if (a === 'help') window.location.href = '/about';
          else if (a === 'start') b.classList.add('blink');
          else if (a === 'alarm') document.body.classList.toggle('alarm-on');
        });
      });
    </script>

    <style is:global>
      :root {
        --bg: #000000;
        --cyan: #00ffff;
        --green: #00ff7f;
        --yellow: #ffff00;
        --magenta: #ff00ff;
        --red: #ff0000;
        --gray: #cccccc;
        --dim: #555555;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }
      ::selection { background: var(--cyan); color: #000; }

      body, html {
        background: var(--bg);
        color: var(--green);
        min-height: 100vh;
        width: 100%;
        overflow-x: hidden;
        font-family: 'VT323', 'Courier New', Courier, monospace;
        font-size: 18px;
        line-height: 1.3;
      }

      /* Scanlines CRT overlay */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 999;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 255, 127, 0.04) 0 1px,
          transparent 1px 3px
        );
      }

      body.alarm-on {
        animation: alarm-flash 0.6s steps(2, end) infinite;
      }
      @keyframes alarm-flash {
        0%, 100% { background: #000; }
        50% { background: #1a0000; }
      }

      a { color: inherit; text-decoration: none; }

      /* ===== TOP SCADA MENU ===== */
      .scada-topbar {
        display: flex;
        flex-wrap: wrap;
        align-items: stretch;
        gap: 2px;
        background: #000;
        padding: 4px 4px 0 4px;
        border-bottom: 1px solid var(--cyan);
      }

      .topbar-btn {
        flex: 1 1 auto;
        min-width: 70px;
        padding: 6px 14px;
        color: #000;
        font-family: 'VT323', monospace;
        font-size: 18px;
        font-weight: bold;
        text-align: center;
        letter-spacing: 1px;
        text-transform: none;
        border: 1px solid #000;
        cursor: pointer;
        transition: filter 0.1s;
      }

      .topbar-btn:hover { filter: brightness(0.8); }

      /* ===== TITLE BAR ===== */
      .title-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 16px;
        background: #000;
        border-bottom: 1px solid var(--green);
        color: var(--cyan);
      }

      .title-name {
        font-size: 22px;
        font-weight: bold;
        letter-spacing: 2px;
        text-shadow: 0 0 4px currentColor;
      }

      .title-ack {
        color: var(--magenta);
        padding: 2px 10px;
        border: 1px solid var(--magenta);
        font-size: 14px;
        letter-spacing: 2px;
      }

      .title-sys {
        color: var(--yellow);
        font-size: 16px;
      }

      /* ===== INTRO TERMINAL ===== */
      .intro-block {
        padding: 20px 24px;
        max-width: 1200px;
        margin: 0 auto;
        color: var(--green);
        border-left: 3px solid var(--cyan);
        margin-top: 16px;
        margin-left: 16px;
        margin-right: 16px;
        background: rgba(0, 255, 127, 0.03);
      }

      .intro-block p {
        font-size: 16px;
        line-height: 1.5;
        letter-spacing: 0.5px;
      }

      /* ===== SCHEMATIC ===== */
      .schematic-wrap {
        position: relative;
        overflow-x: auto;
        padding: 20px 0;
      }

      .schematic {
        position: relative;
        margin: 0 auto;
      }

      .pipes {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
      }

      .pipe-line {
        fill: none;
        stroke: var(--green);
        stroke-width: 2;
        stroke-linecap: square;
        stroke-linejoin: miter;
        filter: drop-shadow(0 0 3px currentColor);
      }

      .pipe-valve {
        fill: #000;
        stroke: var(--cyan);
        stroke-width: 2;
      }

      .pipe-label {
        fill: var(--cyan);
        font-family: 'VT323', monospace;
        font-size: 14px;
        text-shadow: 0 0 3px currentColor;
      }

      /* ===== NODO PRODOTTO ===== */
      .ics-node {
        position: absolute;
        background: #000;
        border: 2px solid var(--cyan);
        box-shadow: 0 0 10px rgba(0, 255, 255, 0.25);
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
        z-index: 5;
        display: flex;
        flex-direction: column;
      }

      .ics-node:hover,
      .ics-node:focus {
        transform: translate(-2px, -2px);
        box-shadow: 4px 4px 0 var(--magenta), 0 0 14px rgba(0, 255, 255, 0.45);
        border-color: var(--magenta);
        outline: none;
      }

      .node-hdr {
        display: flex;
        justify-content: space-between;
        background: var(--magenta);
        color: #000;
        padding: 4px 10px;
        font-weight: bold;
        font-size: 16px;
        letter-spacing: 1px;
      }

      .node-tag { color: #000; }
      .node-name { color: #000; }

      .node-readouts {
        display: flex;
        justify-content: space-between;
        padding: 6px 10px;
        font-size: 18px;
        color: var(--yellow);
        text-shadow: 0 0 3px currentColor;
        border-bottom: 1px solid var(--cyan);
      }

      .node-readouts em {
        font-style: normal;
        color: var(--cyan);
        font-size: 12px;
        margin-left: 2px;
      }

      .node-imgwrap {
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--cyan);
      }

      .node-thumb {
        width: 100%;
        height: 180px;
        object-fit: cover;
        display: block;
        filter: grayscale(70%) contrast(115%) brightness(0.95);
        transition: filter 0.2s, transform 0.2s;
      }

      .ics-node:hover .node-thumb {
        filter: grayscale(0%) contrast(110%);
        transform: scale(1.03);
      }

      .node-open {
        position: absolute;
        top: 6px; right: 6px;
        background: rgba(0, 0, 0, 0.7);
        color: var(--cyan);
        padding: 2px 6px;
        font-size: 14px;
        border: 1px solid var(--cyan);
      }
      .node-open em { font-style: normal; font-size: 11px; color: var(--cyan); }

      .node-load {
        display: flex;
        justify-content: space-between;
        padding: 6px 10px;
        font-size: 16px;
        color: var(--green);
        text-shadow: 0 0 3px currentColor;
        border-bottom: 1px dashed var(--dim);
      }

      .load-bar { letter-spacing: 1px; }

      .node-foot {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 6px 10px;
      }

      .node-price {
        color: var(--cyan);
        font-size: 20px;
        font-weight: bold;
        text-shadow: 0 0 4px currentColor;
      }

      .node-cta {
        color: var(--yellow);
        font-size: 12px;
        letter-spacing: 1px;
      }

      /* ===== EMPTY STATE ===== */
      .empty-state {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 80px 20px;
      }

      .empty-frame {
        border: 2px dashed var(--red);
        padding: 40px 60px;
        text-align: center;
        background: rgba(255, 0, 0, 0.04);
      }

      .empty-title {
        color: var(--red);
        font-size: 26px;
        letter-spacing: 2px;
        margin-bottom: 10px;
        text-shadow: 0 0 4px currentColor;
      }

      .empty-sub {
        color: var(--yellow);
        font-size: 18px;
        margin-bottom: 16px;
      }

      .empty-blink {
        color: var(--green);
        font-size: 28px;
        animation: blink 1s steps(2, end) infinite;
      }

      @keyframes blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
      }

      /* ===== BOTTOM FUNCTION KEY BAR ===== */
      .fn-bar {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        background: #000;
        padding: 6px;
        border-top: 2px solid var(--cyan);
        position: sticky;
        bottom: 0;
        z-index: 50;
      }

      .fn-key {
        flex: 1 1 auto;
        min-width: 80px;
        padding: 8px 6px;
        background: #1a1a1a;
        border: 1px solid #555;
        border-right-color: #222;
        border-bottom-color: #222;
        border-top-color: #888;
        border-left-color: #888;
        font-family: 'VT323', monospace;
        font-size: 16px;
        cursor: pointer;
        letter-spacing: 1px;
        text-shadow: 0 0 2px currentColor;
        transition: filter 0.1s;
      }

      .fn-key:hover { filter: brightness(1.4); }
      .fn-key:active {
        border-top-color: #222;
        border-left-color: #222;
        border-right-color: #888;
        border-bottom-color: #888;
      }

      .fn-key.blink { animation: blink 0.4s steps(2) infinite; }

      /* ===== MODALE ===== */
      .modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 998;
        background: rgba(0, 0, 0, 0.96);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: 20px;
      }
      .modal.active { display: flex; }

      .close-btn {
        position: absolute;
        top: 16px; right: 28px;
        color: var(--cyan);
        font-size: 42px;
        font-weight: bold;
        cursor: pointer;
        font-family: monospace;
        text-shadow: 0 0 4px currentColor;
        z-index: 1;
      }
      .close-btn:hover { color: var(--magenta); }

      .modal-content-wrapper {
        display: flex;
        align-items: center;
        gap: 18px;
        max-width: 95vw;
        max-height: 90vh;
      }

      .modal-inner {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        max-width: 1100px;
        max-height: 85vh;
        background: #000;
        border: 2px solid var(--cyan);
        padding: 16px;
        box-shadow: 0 0 24px rgba(0, 255, 255, 0.3);
      }

      .modal-img {
        max-width: 55vw;
        max-height: 78vh;
        object-fit: contain;
        border: 1px solid var(--cyan);
        background: #050505;
