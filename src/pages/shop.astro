---
// src/pages/manifesto.astro
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop - Strummolo</title>
    <style>
      body {
        background-color: black;
        color: #ff0000;
        font-family: 'Times New Roman', Times, serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        padding: 60px 20px;
        box-sizing: border-box;
      }

      .terminal-container {
        max-width: 900px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      p {
        font-size: 1.6rem;
        line-height: 1.3;
        text-transform: uppercase;
        margin-bottom: 4rem;
      }

      /* --- SHOP --- */
      .shop-container {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        justify-content: center;
        width: 100%;
        max-width: 1000px;
      }

      .product {
        border: 2px solid #ff0000;
        padding: 10px;
        width: 260px;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 15px;
        background-color: transparent;
      }

      .image-wrapper {
        overflow: hidden;
        cursor: pointer;
        position: relative;
      }

      .image-wrapper::after {
        content: 'CLICK TO VIEW';
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
        background-color: black;
        color: white;
        padding: 2px 6px;
        font-family: Arial, sans-serif;
        font-size: 0.7rem;
        letter-spacing: 1px;
        opacity: 0;
        transition: opacity 0.2s;
      }

      .image-wrapper:hover::after {
        opacity: 1;
      }

      .product img.thumb {
        width: 100%;
        height: 260px;
        object-fit: cover;
        background-color: #111;
        filter: grayscale(80%) contrast(120%);
        transition: transform 0.2s, filter 0.2s;
        display: block;
      }

      .image-wrapper:hover img.thumb {
        transform: scale(1.05);
        filter: grayscale(0%) contrast(120%); /* Rivela i colori al passaggio del mouse */
      }

      .product-title {
        font-size: 1.2rem;
        text-transform: uppercase;
        font-weight: bold;
      }

      .dm-note {
        font-family: Arial, sans-serif;
        font-size: 0.9rem;
        color: white;
        text-transform: uppercase;
        letter-spacing: 2px;
        border-top: 1px dashed #ff0000;
        padding-top: 10px;
      }

      /* --- MODALE (GALLERIA FULLSCREEN) --- */
      .modal {
        display: none; /* Nascosta di default */
        position: fixed;
        z-index: 999;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.95); /* Sfondo quasi totalmente nero */
        align-items: center;
        justify-content: center;
        flex-direction: column;
      }

      .modal.active {
        display: flex;
      }

      .modal-content-wrapper {
        display: flex;
        align-items: center;
        gap: 15px;
        max-width: 90vw;
      }

      .modal-img {
        max-width: 70vw;
        max-height: 80vh;
        border: 2px solid #ff0000;
        object-fit: contain;
      }

      .nav-btn {
        background: black;
        border: 2px solid #ff0000;
        color: #ff0000;
        font-size: 1.5rem;
        cursor: pointer;
        padding: 10px 15px;
        font-family: monospace;
        transition: all 0.2s;
      }

      .nav-btn:hover {
        background: #ff0000;
        color: black;
      }

      .close-btn {
        position: absolute;
        top: 20px;
        right: 30px;
        color: #ff0000;
        font-size: 40px;
        font-weight: bold;
        cursor: pointer;
        font-family: monospace;
      }

      .close-btn:hover {
        color: white;
      }

      @media (max-width: 768px) {
        p { font-size: 1.1rem; }
        body { padding: 30px 15px; }
        .product { width: 100%; max-width: 320px; }
        .modal-img { max-width: 85vw; max-height: 70vh; }
        .modal-content-wrapper { flex-direction: column; gap: 20px; }
        .nav-controls { display: flex; gap: 40px; }
      }
    </style>
  </head>
  <body>
    <div class="terminal-container">
      <p>
        This new trend of sharing the best quality of products just because in theory they can last longer it’s just bullshit. We sell you DTG printed tshirt, which, for the market, is just the worst kind of printing. Just face to face, who cares? I mean, stuff has to age, we love to see things with cracks, holes, and many more artefacts that only by wearing your clothes you get. It’s starting to get very boring to have a wardrobe with completely new and intact pieces, in a world full of changes, of liquid thoughts, have some point of references, buy stuff that can have the marks of your life on it, that gets old with cracks on the print and can possibly get printed again one day. This our t-shirt single stitch from the 90s, nothing new, history here guys. Stop wasting.
      </p>
    </div>

    <div class="shop-container">
      <!-- Item 01 -->
      <div class="product">
        <!-- L'attributo data-images accetta un array in formato JSON con i percorsi delle foto -->
        <div class="image-wrapper" data-images='["/img/psq.webp", "/img/mat.webp", "/img/mir.webp"]'>
          <img class="thumb" src="/img/psq.webp" alt="T-shirt 01" />
        </div>
        <div class="product-title">T-Shirt 01</div>
        <div class="dm-note">DM su IG per info</div>
      </div>

      <!-- Item 02 -->
      <div class="product">
        <!-- Esempio di maglia con una sola foto -->
        <div class="image-wrapper" data-images='["/img-maglia-2.jpg"]'>
          <img class="thumb" src="/img/mir.webp" alt="T-shirt 02" />
        </div>
        <div class="product-title">T-Shirt 02</div>
        <div class="dm-note">DM su IG per info</div>
      </div>

      <!-- Item 03 -->
      <div class="product">
        <div class="image-wrapper" data-images='["/img-maglia-3-a.jpg", "/img-maglia-3-b.jpg"]'>
          <img class="thumb" src="/img/mat.webp" alt="T-shirt 03" />
        </div>
        <div class="product-title">T-Shirt 03</div>
        <div class="dm-note">DM su IG per info</div>
      </div>
    </div>

    <!-- Struttura della Modale nascosta (Gallery) -->
    <div id="imageModal" class="modal">
      <span class="close-btn" id="closeModal">&times;</span>
      
      <!-- Su mobile i bottoni passano sotto l'immagine per comodità -->
      <div class="modal-content-wrapper">
        <button id="prevBtn" class="nav-btn" style="display: none;">&lt;</button>
        <img class="modal-img" id="expandedImg" src="" alt="Prodotto Ingrandito" />
        <button id="nextBtn" class="nav-btn" style="display: none;">&gt;</button>
      </div>
      <!-- div usato per tenere i bottoni allineati su mobile -->
      <div class="nav-controls" id="mobileControls" style="display: none;"></div> 
    </div>

    <!-- Script per gestire i click e scorrere le immagini -->
    <script>
      const modal = document.getElementById("imageModal");
      const expandedImg = document.getElementById("expandedImg");
      const closeModal = document.getElementById("closeModal");
      const prevBtn = document.getElementById("prevBtn");
      const nextBtn = document.getElementById("nextBtn");
      const mobileControls = document.getElementById("mobileControls");

      let currentImages = [];
      let currentIndex = 0;

      // Trova tutti i contenitori di immagini cliccabili
      const imageWrappers = document.querySelectorAll('.image-wrapper');

      imageWrappers.forEach(wrapper => {
        wrapper.addEventListener('click', function() {
          // Prende l'array di immagini dall'attributo data-images
          const imagesData = this.getAttribute('data-images');
          
          if (imagesData) {
            currentImages = JSON.parse(imagesData);
            currentIndex = 0;
            updateModalView();
            modal.classList.add('active');
          }
        });
      });

      function updateModalView() {
        expandedImg.src = currentImages[currentIndex];
        
        // Mostra o nascondi i bottoni se c'è più di una foto
        const isMultiple = currentImages.length > 1;
        prevBtn.style.display = isMultiple ? 'block' : 'none';
        nextBtn.style.display = isMultiple ? 'block' : 'none';

        // Riposizionamento bottoni su mobile se serve
        if (window.innerWidth <= 768 && isMultiple) {
          prevBtn.style.display = 'none';
          nextBtn.style.display = 'none';
          mobileControls.style.display = 'flex';
          mobileControls.appendChild(prevBtn);
          mobileControls.appendChild(nextBtn);
          prevBtn.style.display = 'block';
          nextBtn.style.display = 'block';
        }
      }

      // Funzioni di navigazione
      nextBtn.onclick = function(e) {
        e.stopPropagation(); // Evita di chiudere la modale cliccando il bottone
        currentIndex = (currentIndex + 1) % currentImages.length;
        updateModalView();
      }

      prevBtn.onclick = function(e) {
        e.stopPropagation();
        currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
        updateModalView();
      }

      // Chiusura tramite la X
      closeModal.onclick = function() {
        modal.classList.remove('active');
      }

      // Chiusura cliccando fuori dall'immagine (sullo sfondo nero)
      modal.onclick = function(e) {
        if (e.target === modal || e.target.classList.contains('modal-content-wrapper')) {
          modal.classList.remove('active');
        }
      }
    </script>
  </body>
</html>