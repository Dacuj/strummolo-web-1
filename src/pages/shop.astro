---
import { getCollection } from 'astro:content';

const products = (await getCollection('prodotti', ({ data }) => data.available !== false))
  .sort((a, b) => (a.data.order ?? Infinity) - (b.data.order ?? Infinity));
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shop // Strummolo</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="description" content="Strummolo shop — per ordinare scrivici su Instagram @strummolo123." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
  </head>
  <body>

    <a href="/" class="logo" aria-label="strummolo123">
      <span>s</span><span>t</span><span>r</span><span>u</span><span>m</span><span>m</span><span>o</span><span>l</span><span>o</span><span class="arrows">123</span>
    </a>

    <main class="shop-col">
      {products.length === 0 ? (
        <div class="shop-empty">
          <p>Nessun prodotto in stock — torna presto.</p>
        </div>
      ) : (
        products.map((p) => (
          <a class="outfit" href={`/shop/${p.slug}`} aria-label={`Apri ${p.data.title}`}>
            <h2 class="outfit-title">{p.data.title}</h2>

            {p.data.head && (
              <img class="piece" src={p.data.head} alt="" loading="lazy" />
            )}

            <img class="piece" src={p.data.images[0]} alt={p.data.title} loading="lazy" />

            {p.data.bottom && (
              <img class="piece" src={p.data.bottom} alt="" loading="lazy" />
            )}
          </a>
        ))
      )}
    </main>

    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      ::selection { background: #fff; color: #000; }

      html, body { height: 100%; }

      body {
        min-height: 100vh;
        font-family: Arial, Helvetica, sans-serif;
        color: #fff;
        background-color: #000;
        overflow-x: hidden;
      }

      a { color: inherit; text-decoration: none; }

      /* ===== LOGO (identico alla home) ===== */
      .logo {
        position: fixed;
        top: 14px;
        left: 50%;
        transform: translateX(-50%) rotate(-1deg);
        z-index: 1500;
        display: flex;
        gap: 2px;
        padding: 9px 11px;
        background: rgba(0, 0, 0, 0.8);
        font-family: 'Press Start 2P', cursive;
        font-size: 0.8rem;
        text-decoration: none;
        text-shadow: 2px 2px 0 #000;
      }
      .logo span { color: #fff; }
      .logo span:nth-child(1) { color: #ea4335; }
      .logo span:nth-child(2) { color: #fbbc05; }
      .logo span:nth-child(3) { color: #4285f4; }
      .logo span:nth-child(4) { color: #34a853; }
      .logo span:nth-child(5) { color: #ea4335; }
      .logo .arrows { color: #4285f4; margin-left: 5px; }
      .logo:hover { opacity: 0.85; }

      /* ===== COLONNA "MOBILE" CENTRATA ===== */
      .shop-col {
        width: 100%;
        max-width: 440px;
        margin: 0 auto;
        background: #000;
        padding-top: 64px;
        padding-bottom: 64px;
      }

      /* ===== OUTFIT (un prodotto = un corpo, tutto cliccabile) ===== */
      .outfit {
        display: block;
        padding: 24px 0 56px;
        cursor: pointer;
      }

      .outfit-title {
        text-align: center;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.1;
        margin: 0 0 18px;
        padding: 0 12px;
        word-break: break-word;
        transition: opacity 0.2s ease;
      }

      /* I pezzi si impilano a filo per comporre il corpo.
         Niente filtri di default: lo sfondo nero gestisce i PNG trasparenti. */
      .piece {
        display: block;
        max-width: 100%;
        height: auto;
        margin: 0 auto;
        transition: filter 0.2s ease;
      }

      /* Feedback al passaggio: l'intero outfit reagisce */
      .outfit:hover .piece {
        filter: drop-shadow(0 0 16px rgba(255, 255, 255, 0.22));
      }
      .outfit:hover .outfit-title {
        text-decoration: underline;
        text-underline-offset: 6px;
      }

      /* ===== STATO VUOTO ===== */
      .shop-empty {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 40px 20px;
        opacity: 0.75;
        font-size: 16px;
        letter-spacing: 1px;
      }

      @media (max-width: 480px) {
        .logo { font-size: 0.6rem; top: 10px; padding: 7px 9px; }
        .shop-col { padding-top: 52px; }
        .outfit-title { font-size: 34px; }
      }
    </style>
  </body>
</html>
