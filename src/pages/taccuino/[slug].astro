import { getCollection } from 'astro:content';

// 1. Genera i percorsi statici per ogni articolo
export async function getStaticPaths() {
  const posts = await getCollection('taccuino');
  posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { 
        post,
        nextPost: index > 0 ? posts[index - 1] : null 
    },
  }));
}

const { post, nextPost } = Astro.props;
const { Content } = await post.render();

const formatSysDate = (date: Date) => {
    return date.toISOString().replace('T', ' // ').substring(0, 19);
};

// --- PRODUCT EMBED DATA ---
// Carico TUTTI i prodotti shop disponibili. Lo script inline più sotto
// scorre i <div class="product-embed" data-slug="..."> dentro l'articolo
// e li sostituisce con la card prodotto + CTA acquisto.
const allProducts = await getCollection('prodotti');
const productMap: Record<string, {
    title: string;
    description: string;
    price: string;
    image: string;
    available: boolean;
}> = {};
for (const p of allProducts) {
    productMap[p.slug] = {
        title: p.data.title,
        description: p.data.description,
        price: p.data.price,
        image: (p.data.images && p.data.images[0]) || '',
        available: p.data.available !== false,
    };
}
const INSTAGRAM_URL = 'https://instagram.com/strummolo123';

// Prodotti collegati esplicitamente dal frontmatter (campo del CMS).
// Filtra eventuali slug puntati a prodotti eliminati.
const linkedProductSlugs: string[] = (post.data as any).prodotti_collegati || [];
const linkedProducts = linkedProductSlugs
    .map((slug) => ({ slug, ...productMap[slug] }))
    .filter((p) => p && p.title);

// --- GENERATORE WIREFRAME ---
const generateWireframe = (offsetX: number, offsetY: number, scaleY: number) => {
    let paths = [];
    const rows = 35;
    const cols = 50;
    const spacingX = 12;
    const spacingY = 6;

    // Linee orizzontali
    for (let y = 0; y < rows; y++) {
        let path = `M `;
        for (let x = 0; x < cols; x++) {
            let px = offsetX + (x * spacingX) - (y * spacingX * 0.3);
            let py = offsetY + (y * spacingY) - (Math.sin(x * 0.3) * Math.cos(y * 0.4) * scaleY) - (Math.sin(x * 0.8) * 10);
            path += `${px},${py} L `;
        }
        paths.push(path.slice(0, -3));
    }
    
    // Linee verticali
    for (let x = 0; x < cols; x++) {
        let path = `M `;
        for (let y = 0; y < rows; y++) {
            let px = offsetX + (x * spacingX) - (y * spacingX * 0.3);
            let py = offsetY + (y * spacingY) - (Math.sin(x * 0.3) * Math.cos(y * 0.4) * scaleY) - (Math.sin(x * 0.8) * 10);
            path += `${px},${py} L `;
        }
        paths.push(path.slice(0, -3));
    }
    return paths;
};

const wireframe1 = generateWireframe(-100, 50, 60);
const wireframe2 = generateWireframe(-50, 300, 80);
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>0x{post.slug.toUpperCase()} | strummolo </title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta name="description" content={post.data.description} />

    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:type" content="article" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
</head>
<body>

    <!-- LAYER BACKGROUND: WIREFRAME ROSSO DENSO -->
    <svg class="jodi-wireframe" viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
        {wireframe1.map(path => (
            <path d={path} fill="none" stroke="#ff0000" stroke-width="0.8" vector-effect="non-scaling-stroke" />
        ))}
        {wireframe2.map(path => (
            <path d={path} fill="none" stroke="#ff0000" stroke-width="1.2" vector-effect="non-scaling-stroke" />
        ))}
    </svg>

    <!-- NAVBAR DI SISTEMA -->
    <nav class="sys-nav">
        <a href="/" class="sys-btn">!HOME></a>
        <span class="sys-info"> {formatSysDate(new Date())}</span>
        <a href="/archive" class="sys-btn">/TACCUINO.!)</a>
    </nav>

    <!-- WRAPPER DEI BOX -->
    <main class="jodi-window-wrapper">
        
        <!-- BOX 1: DESCRIZIONE -->
        <aside class="jodi-window window-desc">
            <header class="window-header">
                <h2 class="file-name">DESC</h2>
                <span class="file-size">READ</span>
            </header>
            <div class="window-content desc-body">
                <p><strong>[TITLE]:</strong> {post.data.title}</p>
                <p><strong>[DATE]:</strong> {formatSysDate(post.data.date)}</p>
                <div class="desc-text">
                    > {post.data.description}
                </div>
            </div>
        </aside>

        <!-- BOX 2: CONTENUTO PRINCIPALE -->
        <article class="jodi-window window-main">
            <header class="window-header">
                <h1 class="file-name">{post.data.title.toUpperCase().replace(/\s/g, '_')}.TXT</h1>
                <span class="file-size">{Math.floor(Math.random() * 800 + 10)} KB</span>
            </header>

            <div class="window-content markdown-body">
                <Content />
            </div>
        </article>

        <!-- ESPANSIONE PRODUCT EMBEDS A RUNTIME (per chi inserisce manualmente
             <div class="product-embed" data-slug="X"> nel markdown source) -->
        <script is:inline define:vars={{ productMap }}>
            (function() {
                function esc(s) {
                    return String(s == null ? '' : s)
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#39;');
                }

                const nodes = document.querySelectorAll('.product-embed[data-slug]');
                nodes.forEach(function(el) {
                    const slug = el.getAttribute('data-slug');
                    const p = productMap[slug];
                    if (!p) {
                        el.classList.add('minimal-embed-missing');
                        el.innerHTML = '<em>[prodotto non trovato: ' + esc(slug) + ']</em>';
                        return;
                    }

                    const imgHTML = p.image
                        ? '<img class="minimal-embed-img" src="' + esc(p.image) + '" alt="' + esc(p.title) + '" loading="lazy" />'
                        : '<div class="minimal-embed-noimg">[no image]</div>';

                    el.classList.add('minimal-embed');
                    el.innerHTML =
                        '<a class="minimal-embed-link" href="/shop/' + esc(slug) + '">' +
                            imgHTML +
                            '<span class="minimal-embed-title">' + esc(p.title) + '</span>' +
                            '<span class="minimal-embed-label">shop →</span>' +
                        '</a>';
                });
            })();
        </script>

        <!-- PRODOTTI COLLEGATI (campo CMS prodotti_collegati) -->
        {linkedProducts.length > 0 && (
            <section class="minimal-embed-section">
                <div class="minimal-embed-section-hdr">&gt;&gt; SHOP</div>
                <div class="minimal-embed-list">
                    {linkedProducts.map((p) => (
                        <div class="minimal-embed">
                            <a class="minimal-embed-link" href={`/shop/${p.slug}`}>
                                {p.image ? (
                                    <img class="minimal-embed-img" src={p.image} alt={p.title} loading="lazy" />
                                ) : (
                                    <div class="minimal-embed-noimg">[no image]</div>
                                )}
                                <span class="minimal-embed-title">{p.title}</span>
                                <span class="minimal-embed-label">shop →</span>
                            </a>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- FOOTER / NEXT POST -->
        {nextPost && (
            <footer class="sys-footer">
                <a href={`/taccuino/${nextPost.slug}`} class="next-link">
                    >> NEXT: {nextPost.data.title.toUpperCase()}
                </a>
            </footer>
        )}
    </main>

</body>
</html>

<style is:global>
    /* --- RESET TOTALE BRUTALISTA --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    ::selection {
        background: #000;
        color: #ff0000;
    }

    body, html {
        background-color: #000000;
        color: #ff0000;
        min-height: 100vh;
        width: 100vw;
        overflow-x: hidden;
        font-family: "Courier New", Courier, monospace;
        font-size: 16px;
        line-height: 1.4;
    }

    /* --- WIREFRAME BACKGROUND --- */
    .jodi-wireframe {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
    }

    /* --- NAVIGAZIONE TOP --- */
    .sys-nav {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        padding: 10px 20px;
        background: rgba(0,0,0,0.8);
        border-bottom: 1px solid #ff0000;
        font-weight: bold;
    }

    .sys-btn {
        color: #ff0000;
        text-decoration: none;
    }

    .sys-btn:hover {
        background: #ff0000;
        color: #000;
    }

    .sys-info { display: none; }
    @media (min-width: 768px) { .sys-info { display: block; } }

    /* --- CONTENITORE FINESTRE --- */
    .jodi-window-wrapper {
        position: relative;
        z-index: 10;
        max-width: 750px;
        margin: 40px auto;
        padding: 0 15px;
    }

    /* Base comune per i box finestre */
    .jodi-window {
        background-color: #8a8a8a; /* Grigio classico Jodi */
        border: 6px solid #ff0000; /* Bordo massiccio rosso */
        box-shadow: 15px 15px 0px rgba(0,0,0,0.9);
        display: flex;
        flex-direction: column;
        margin-bottom: 40px; /* Spazio tra i box */
    }

    /* Stile specifico per sfalsare il box principale */
    .window-main {
        transform: translateX(10px); /* Sfalsamento "finto pop-up" */
    }

    /* Header delle finestre */
    .window-header {
        display: flex;
        justify-content: space-between;
        background: #ff0000;
        color: #000;
        padding: 5px 10px;
        font-weight: bold;
        border-bottom: 2px solid #000;
    }

    .file-name { font-size: 16px; margin: 0; }
    .file-size { font-size: 14px; }

    /* Base contenitore interno (Grigio per la leggibilità) */
    .window-content {
        padding: 20px 30px;
        color: #000000;
    }

    /* --- STILI BOX 1 (DESCRIZIONE) --- */
    .desc-body p {
        margin-bottom: 5px;
        font-size: 14px;
        border-bottom: 1px dashed rgba(0,0,0,0.3);
    }
    
    .desc-text {
        margin-top: 15px;
        background: #000;
        color: #ff0000;
        padding: 15px;
        border: 2px inset #fff;
        font-weight: bold;
    }

    /* --- STILI BOX 2 (MARKDOWN ARTICOLO) --- */
    .markdown-body {
        min-height: 200px;
    }

    .markdown-body p { margin-bottom: 20px; font-size: 16px; }
    
    .markdown-body a {
        color: #000;
        text-decoration: underline;
        font-weight: bold;
    }
    
    .markdown-body a:hover {
        background: #ff0000;
        color: #fff;
        text-decoration: none;
    }

    .markdown-body h1, .markdown-body h2, .markdown-body h3 {
        font-size: 22px;
        border-bottom: 2px dashed #000;
        margin: 30px 0 15px 0;
        padding-bottom: 5px;
    }

    .markdown-body blockquote {
        border-left: 4px solid #ff0000;
        padding-left: 15px;
        margin-left: 0;
        font-style: italic;
        background: rgba(0,0,0,0.1);
        padding-top: 10px;
        padding-bottom: 10px;
    }

    .markdown-body pre {
        background: #000;
        color: #ff0000;
        padding: 15px;
        border: 2px inset #fff;
        overflow-x: auto;
        margin-bottom: 20px;
    }

    .markdown-body img {
        max-width: 100%;
        height: auto;
        border: 2px solid #000;
        filter: grayscale(100%) contrast(200%) sepia(100%) hue-rotate(-50deg) saturate(500%);
        margin: 20px 0;
    }

    /* --- FOOTER DI SISTEMA --- */
    .sys-footer {
        margin-top: 50px;
        margin-bottom: 50px;
        text-align: right;
        transform: translateX(10px);
    }

    .next-link {
        display: inline-block;
        background: #000;
        color: #ff0000;
        border: 2px solid #ff0000;
        padding: 10px 15px;
        font-weight: bold;
        text-decoration: none;
        font-size: 18px;
    }

    .next-link:hover {
        background: #ff0000;
        color: #000;
    }

    /* Finti quadretti glitch sul box principale */
    .window-main::before {
        content: "";
        position: absolute;
        top: 40%;
        left: -15px;
        width: 10px;
        height: 10px;
        background: #8a8a8a;
        box-shadow: 0 30px 0 #8a8a8a, -10px 40px 0 #8a8a8a;
    }

    /* ============================================================
       MINIMAL EMBED — card prodotto inline negli articoli.
       Allineata allo stile minimale di /shop (solo PNG + link testuale).
       Usata sia dal render server-side della sezione SHOP che dallo script
       inline che espande <div class="product-embed" data-slug="X">.
       ============================================================ */

    .minimal-embed-section {
        margin: 60px 0 40px 0;
    }

    .minimal-embed-section-hdr {
        font-family: "Courier New", monospace;
        font-size: 14px;
        color: #ff0000;
        letter-spacing: 2px;
        margin-bottom: 30px;
        padding-bottom: 8px;
        border-bottom: 1px solid #ff0000;
        font-weight: bold;
    }

    .minimal-embed-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 40px 30px;
        justify-items: center;
    }

    .minimal-embed {
        display: block;
        text-align: center;
        max-width: 240px;
    }

    .minimal-embed-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .minimal-embed-img {
        display: block;
        max-width: 100%;
        max-height: 240px;
        margin: 0 auto;
        /* NESSUN filtro: il PNG del prodotto deve restare fedele */
    }

    .minimal-embed-noimg {
        width: 100%;
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #111;
        color: #ff0000;
        font-family: "Courier New", monospace;
        font-size: 13px;
        letter-spacing: 1px;
    }

    .minimal-embed-title {
        display: block;
        margin-top: 14px;
        font-family: "Courier New", monospace;
        font-size: 13px;
        color: #fff;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.9;
    }

    .minimal-embed-label {
        display: inline-block;
        margin-top: 10px;
        font-family: "Courier New", monospace;
        font-size: 13px;
        color: #ff0000;
        letter-spacing: 2px;
        text-transform: lowercase;
        border-bottom: 1px solid #ff0000;
        padding-bottom: 2px;
        transition: background 0.15s, color 0.15s;
    }

    .minimal-embed-link:hover .minimal-embed-label {
        background: #ff0000;
        color: #000;
    }

    .minimal-embed-link:hover .minimal-embed-title {
        opacity: 1;
    }

    /* Singolo embed inline nel markdown (non dentro la sezione SHOP):
       gli dà un po' di respiro tra paragrafi */
    .markdown-body .minimal-embed:not(.minimal-embed-list .minimal-embed) {
        margin: 40px auto;
    }

    .minimal-embed-missing {
        margin: 30px auto;
        padding: 14px 20px;
        border: 1px dashed #ff0000;
        color: #ff0000;
        background: #000;
        font-family: "Courier New", monospace;
        text-align: center;
        font-size: 13px;
    }

    @media (max-width: 600px) {
        .minimal-embed-list {
            grid-template-columns: repeat(2, 1fr);
            gap: 30px 16px;
        }
        .minimal-embed-img { max-height: 180px; }
        .minimal-embed-title { font-size: 11px; letter-spacing: 1.5px; }
        .minimal-embed-label { font-size: 12px; }
    }
</style>