---
import { getCollection } from 'astro:content';

// 1. Genera i percorsi statici per ogni articolo
export async function getStaticPaths() {
  const posts = await getCollection('taccuino');
  posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: { 
        post,
        nextPost: index > 0 ? posts[index - 1] : null 
    },
  }));
}

const { post, nextPost } = Astro.props;
const { Content } = await post.render();

const formatSysDate = (date: Date) => {
    return date.toISOString().replace('T', ' // ').substring(0, 19);
};

// --- PRODUCT EMBED DATA ---
// Carico TUTTI i prodotti shop disponibili. Lo script inline più sotto
// scorre i <div class="product-embed" data-slug="..."> dentro l'articolo
// e li sostituisce con la card prodotto + CTA acquisto.
const allProducts = await getCollection('prodotti');
const productMap: Record<string, {
    title: string;
    description: string;
    price: string;
    image: string;
    available: boolean;
}> = {};
for (const p of allProducts) {
    productMap[p.slug] = {
        title: p.data.title,
        description: p.data.description,
        price: p.data.price,
        image: (p.data.images && p.data.images[0]) || '',
        available: p.data.available !== false,
    };
}
const INSTAGRAM_URL = 'https://instagram.com/strummolo';

// --- GENERATORE WIREFRAME ---
const generateWireframe = (offsetX: number, offsetY: number, scaleY: number) => {
    let paths = [];
    const rows = 35;
    const cols = 50;
    const spacingX = 12;
    const spacingY = 6;

    // Linee orizzontali
    for (let y = 0; y < rows; y++) {
        let path = `M `;
        for (let x = 0; x < cols; x++) {
            let px = offsetX + (x * spacingX) - (y * spacingX * 0.3);
            let py = offsetY + (y * spacingY) - (Math.sin(x * 0.3) * Math.cos(y * 0.4) * scaleY) - (Math.sin(x * 0.8) * 10);
            path += `${px},${py} L `;
        }
        paths.push(path.slice(0, -3));
    }
    
    // Linee verticali
    for (let x = 0; x < cols; x++) {
        let path = `M `;
        for (let y = 0; y < rows; y++) {
            let px = offsetX + (x * spacingX) - (y * spacingX * 0.3);
            let py = offsetY + (y * spacingY) - (Math.sin(x * 0.3) * Math.cos(y * 0.4) * scaleY) - (Math.sin(x * 0.8) * 10);
            path += `${px},${py} L `;
        }
        paths.push(path.slice(0, -3));
    }
    return paths;
};

const wireframe1 = generateWireframe(-100, 50, 60);
const wireframe2 = generateWireframe(-50, 300, 80);
---

<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>0x{post.slug.toUpperCase()} | strummolo </title>
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta name="description" content={post.data.description} />

    <meta property="og:title" content={post.data.title} />
    <meta property="og:description" content={post.data.description} />
    <meta property="og:type" content="article" />

    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
</head>
<body>

    <!-- LAYER BACKGROUND: WIREFRAME ROSSO DENSO -->
    <svg class="jodi-wireframe" viewBox="0 0 600 600" preserveAspectRatio="xMidYMid slice">
        {wireframe1.map(path => (
            <path d={path} fill="none" stroke="#ff0000" stroke-width="0.8" vector-effect="non-scaling-stroke" />
        ))}
        {wireframe2.map(path => (
            <path d={path} fill="none" stroke="#ff0000" stroke-width="1.2" vector-effect="non-scaling-stroke" />
        ))}
    </svg>

    <!-- NAVBAR DI SISTEMA -->
    <nav class="sys-nav">
        <a href="/" class="sys-btn">!HOME></a>
        <span class="sys-info"> {formatSysDate(new Date())}</span>
        <a href="/archive" class="sys-btn">/TACCUINO.!)</a>
    </nav>

    <!-- WRAPPER DEI BOX -->
    <main class="jodi-window-wrapper">
        
        <!-- BOX 1: DESCRIZIONE -->
        <aside class="jodi-window window-desc">
            <header class="window-header">
                <h2 class="file-name">DESC</h2>
                <span class="file-size">READ</span>
            </header>
            <div class="window-content desc-body">
                <p><strong>[TITLE]:</strong> {post.data.title}</p>
                <p><strong>[DATE]:</strong> {formatSysDate(post.data.date)}</p>
                <div class="desc-text">
                    > {post.data.description}
                </div>
            </div>
        </aside>

        <!-- BOX 2: CONTENUTO PRINCIPALE -->
        <article class="jodi-window window-main">
            <header class="window-header">
                <h1 class="file-name">{post.data.title.toUpperCase().replace(/\s/g, '_')}.TXT</h1>
                <span class="file-size">{Math.floor(Math.random() * 800 + 10)} KB</span>
            </header>

            <div class="window-content markdown-body">
                <Content />
            </div>
        </article>

        <!-- ESPANSIONE PRODUCT EMBEDS A RUNTIME -->
        <script is:inline define:vars={{ productMap, instagramUrl: INSTAGRAM_URL }}>
            (function() {
                function esc(s) {
                    return String(s == null ? '' : s)
                        .replace(/&/g, '&amp;')
                        .replace(/</g, '&lt;')
                        .replace(/>/g, '&gt;')
                        .replace(/"/g, '&quot;')
                        .replace(/'/g, '&#39;');
                }

                const nodes = document.querySelectorAll('.product-embed[data-slug]');
                nodes.forEach(function(el) {
                    const slug = el.getAttribute('data-slug');
                    const p = productMap[slug];
                    if (!p) {
                        el.classList.add('product-embed-missing');
                        el.innerHTML = '<em>[PRODOTTO NON TROVATO: ' + esc(slug) + ']</em>';
                        return;
                    }

                    const imgHTML = p.image
                        ? '<img class="product-embed-img" src="' + esc(p.image) + '" alt="' + esc(p.title) + '" loading="lazy" />'
                        : '<div class="product-embed-img product-embed-noimg">[NO IMAGE]</div>';

                    const descHTML = p.description
                        ? '<p class="product-embed-desc">' + esc(p.description) + '</p>'
                        : '';

                    const ctaLabel = p.available
                        ? '&gt;&gt; COMPRA / DM SU IG'
                        : '&gt;&gt; SOLD OUT — CHIEDI DISPONIBILITÀ';

                    el.innerHTML =
                        '<aside class="product-embed-card">' +
                            '<a class="product-embed-link" href="/shop" aria-label="Apri shop">' +
                                imgHTML +
                            '</a>' +
                            '<div class="product-embed-info">' +
                                '<span class="product-embed-meta">// PRODOTTO_SHOP // ' + esc(p.price) + '</span>' +
                                '<h3 class="product-embed-title">' + esc(p.title) + '</h3>' +
                                descHTML +
                                '<a class="product-embed-cta" href="' + esc(instagramUrl) + '" target="_blank" rel="noopener noreferrer">' +
                                    ctaLabel +
                                '</a>' +
                            '</div>' +
                        '</aside>';
                });
            })();
        </script>

        <!-- FOOTER / NEXT POST -->
        {nextPost && (
            <footer class="sys-footer">
                <a href={`/taccuino/${nextPost.slug}`} class="next-link">
                    >> NEXT: {nextPost.data.title.toUpperCase()}
                </a>
            </footer>
        )}
    </main>

</body>
</html>

<style is:global>
    /* --- RESET TOTALE BRUTALISTA --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    ::selection {
        background: #000;
        color: #ff0000;
    }

    body, html {
        background-color: #000000;
        color: #ff0000;
        min-height: 100vh;
        width: 100vw;
        overflow-x: hidden;
        font-family: "Courier New", Courier, monospace;
        font-size: 16px;
        line-height: 1.4;
    }

    /* --- WIREFRAME BACKGROUND --- */
    .jodi-wireframe {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 0;
        pointer-events: none;
    }

    /* --- NAVIGAZIONE TOP --- */
    .sys-nav {
        position: relative;
        z-index: 10;
        display: flex;
        justify-content: space-between;
        padding: 10px 20px;
        background: rgba(0,0,0,0.8);
        border-bottom: 1px solid #ff0000;
        font-weight: bold;
    }

    .sys-btn {
        color: #ff0000;
        text-decoration: none;
    }

    .sys-btn:hover {
        background: #ff0000;
        color: #000;
    }

    .sys-info { display: none; }
    @media (min-width: 768px) { .sys-info { display: block; } }

    /* --- CONTENITORE FINESTRE --- */
    .jodi-window-wrapper {
        position: relative;
        z-index: 10;
        max-width: 750px;
        margin: 40px auto;
        padding: 0 15px;
    }

    /* Base comune per i box finestre */
    .jodi-window {
        background-color: #8a8a8a; /* Grigio classico Jodi */
        border: 6px solid #ff0000; /* Bordo massiccio rosso */
        box-shadow: 15px 15px 0px rgba(0,0,0,0.9);
        display: flex;
        flex-direction: column;
        margin-bottom: 40px; /* Spazio tra i box */
    }

    /* Stile specifico per sfalsare il box principale */
    .window-main {
        transform: translateX(10px); /* Sfalsamento "finto pop-up" */
    }

    /* Header delle finestre */
    .window-header {
        display: flex;
        justify-content: space-between;
        background: #ff0000;
        color: #000;
        padding: 5px 10px;
        font-weight: bold;
        border-bottom: 2px solid #000;
    }

    .file-name { font-size: 16px; margin: 0; }
    .file-size { font-size: 14px; }

    /* Base contenitore interno (Grigio per la leggibilità) */
    .window-content {
        padding: 20px 30px;
        color: #000000;
    }

    /* --- STILI BOX 1 (DESCRIZIONE) --- */
    .desc-body p {
        margin-bottom: 5px;
        font-size: 14px;
        border-bottom: 1px dashed rgba(0,0,0,0.3);
    }
    
    .desc-text {
        margin-top: 15px;
        background: #000;
        color: #ff0000;
        padding: 15px;
        border: 2px inset #fff;
        font-weight: bold;
    }

    /* --- STILI BOX 2 (MARKDOWN ARTICOLO) --- */
    .markdown-body {
        min-height: 200px;
    }

    .markdown-body p { margin-bottom: 20px; font-size: 16px; }
    
    .markdown-body a {
        color: #000;
        text-decoration: underline;
        font-weight: bold;
    }
    
    .markdown-body a:hover {
        background: #ff0000;
        color: #fff;
        text-decoration: none;
    }

    .markdown-body h1, .markdown-body h2, .markdown-body h3 {
        font-size: 22px;
        border-bottom: 2px dashed #000;
        margin: 30px 0 15px 0;
        padding-bottom: 5px;
    }

    .markdown-body blockquote {
        border-left: 4px solid #ff0000;
        padding-left: 15px;
        margin-left: 0;
        font-style: italic;
        background: rgba(0,0,0,0.1);
        padding-top: 10px;
        padding-bottom: 10px;
    }

    .markdown-body pre {
        background: #000;
        color: #ff0000;
        padding: 15px;
        border: 2px inset #fff;
        overflow-x: auto;
        margin-bottom: 20px;
    }

    .markdown-body img {
        max-width: 100%;
        height: auto;
        border: 2px solid #000;
        filter: grayscale(100%) contrast(200%) sepia(100%) hue-rotate(-50deg) saturate(500%);
        margin: 20px 0;
    }

    /* --- FOOTER DI SISTEMA --- */
    .sys-footer {
        margin-top: 50px;
        margin-bottom: 50px;
        text-align: right;
        transform: translateX(10px);
    }

    .next-link {
        display: inline-block;
        background: #000;
        color: #ff0000;
        border: 2px solid #ff0000;
        padding: 10px 15px;
        font-weight: bold;
        text-decoration: none;
        font-size: 18px;
    }

    .next-link:hover {
        background: #ff0000;
        color: #000;
    }

    /* Finti quadretti glitch sul box principale */
    .window-main::before {
        content: "";
        position: absolute;
        top: 40%;
        left: -15px;
        width: 10px;
        height: 10px;
        background: #8a8a8a;
        box-shadow: 0 30px 0 #8a8a8a, -10px 40px 0 #8a8a8a;
    }

    /* ============================================================
       PRODUCT EMBED — card inserita da Decap nei post
       Riempita a runtime dallo script <script is:inline> sopra.
       L'immagine eredita il filtro brutalist di .markdown-body img.
       ============================================================ */

    .product-embed {
        display: block;
        margin: 40px 0;
    }

    .product-embed-card {
        background: #fff;
        border: 4px solid #ff0000;
        box-shadow: 10px 10px 0 #000;
        position: relative;
        display: block;
    }

    .product-embed-card::before {
        content: "// SHOP_BLOCK //";
        position: absolute;
        top: -14px;
        left: 12px;
        background: #ff0000;
        color: #000;
        padding: 1px 10px;
        font-size: 11px;
        font-weight: bold;
        letter-spacing: 1px;
        font-family: "Courier New", monospace;
        border: 2px solid #000;
    }

    .product-embed-link {
        display: block;
        text-decoration: none;
        background: #000;
    }

    .product-embed-img {
        display: block;
        width: 100%;
        height: auto;
        max-height: 480px;
        object-fit: contain;
        background: #000;
        margin: 0;
        border: none;
        border-bottom: 2px solid #000;
        /* Stesso filtro di .markdown-body img */
        filter: grayscale(100%) contrast(200%) sepia(100%) hue-rotate(-50deg) saturate(500%);
        transition: filter 0.2s;
    }

    .product-embed-link:hover .product-embed-img {
        filter: grayscale(0%) contrast(110%);
    }

    .product-embed-noimg {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 200px;
        background: #000;
        color: #ff0000;
        font-weight: bold;
        letter-spacing: 2px;
    }

    .product-embed-info {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .product-embed-meta {
        color: #ff0000;
        font-size: 12px;
        font-family: "Courier New", monospace;
        letter-spacing: 1px;
        font-weight: bold;
    }

    .product-embed-title {
        font-size: 24px;
        color: #000;
        font-weight: bold;
        text-transform: uppercase;
        margin: 0;
        padding: 0;
        border: none;
        line-height: 1.1;
    }

    /* Override del default .markdown-body h1/h2/h3 che ha border-bottom dashed */
    .markdown-body .product-embed-title {
        border-bottom: none;
        padding-bottom: 0;
        margin: 0;
    }

    .product-embed-desc {
        color: #000;
        font-size: 15px;
        margin: 0;
        line-height: 1.4;
    }

    .markdown-body .product-embed-desc {
        margin-bottom: 0;
        font-size: 15px;
    }

    .product-embed-cta {
        display: block;
        text-align: center;
        margin-top: 12px;
        background: #000;
        color: #ff0000 !important;
        border: 3px solid #ff0000;
        padding: 16px;
        font-weight: bold;
        font-size: 20px;
        text-transform: uppercase;
        letter-spacing: 3px;
        text-decoration: none !important;
        transition: background 0.15s, color 0.15s;
        font-family: "Courier New", monospace;
    }

    .product-embed-cta:hover {
        background: #ff0000 !important;
        color: #000 !important;
        text-decoration: none !important;
    }

    .product-embed-missing {
        padding: 20px;
        border: 2px dashed #ff0000;
        color: #ff0000;
        background: #000;
        font-family: "Courier New", monospace;
        text-align: center;
    }

    @media (max-width: 600px) {
        .product-embed-card { box-shadow: 6px 6px 0 #000; }
        .product-embed-title { font-size: 20px; }
        .product-embed-cta { font-size: 16px; padding: 14px; letter-spacing: 2px; }
        .product-embed-img { max-height: 360px; }
    }
</style>