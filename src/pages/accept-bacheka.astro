---
// src/pages/disclaimer-chat.astro

// Sostituisci questo link con il percorso reale della tua pagina chat
const urlChat = "/la-tua-chat-dal-vivo";
---

<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Disclaimer Chat - Sturmmolo</title>
  </head>
  <body>
    <main class="terminal-container">
      <div class="content">
        <p>
         You may enter this live chat at any time by accepting that you will leave a permanent digital footprint upon any and all of our servers and all related databases and all logs thereof, whether generated under the terms of this agreement or otherwise. We disclaim any and all responsibility immediately and without notice from us if, in their sole discretion, any user chooses to write whatever they want, regardless of any term or provision of this agreement. Upon entry, you must accept all risks associated with materials published on this site and any and all of our other sites and all copies thereof, whether made under the terms of this agreement or otherwise.
        </p>
        <a href=/bacheka class="accept-btn">ACCEPT</a>
      </div>
    </main>
  </body>
</html>

<style>
  /* Resetta i margini e imposta lo sfondo nero su tutto il body */
  :global(body) {
    margin: 0;
    padding: 0;
    background-color: #000000;
  }

  .terminal-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    background-color: #000000;
    padding: 2rem;
    box-sizing: border-box;
  }

  .content {
    max-width: 850px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  /* Stile del testo: verde fluo e font serif per replicare lo screenshot */
  p {
    color: #00ff00;
    font-family: "Times New Roman", Times, serif;
    font-size: 1.6rem;
    line-height: 1.3;
    margin: 0;
  }

  /* Stile del bottone ACCEPT: piccolo, sfondo bianco, testo nero */
  .accept-btn {
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
    padding: 2px 10px;
    font-family: Arial, sans-serif;
    font-size: 0.8rem;
    font-weight: bold;
    border: 1px solid #ffffff;
    cursor: pointer;
    text-transform: uppercase;
  }
  
  .accept-btn:hover {
    background-color: #cccccc;
  }
</style>