---
import { getCollection } from 'astro:content';

// Recuperiamo tutti gli articoli reali dalla cartella 'taccuino'
const posts = await getCollection('taccuino');

// Ordiniamo per data (dal più recente)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Funzione helper per le immagini
const getPostImage = (style: string) => {
    switch (style) {
        case 'tech': return 'https://static.wikia.nocookie.net/aesthetics/images/4/44/Tumblr_b54a31622a1e8dfa780a25c1602aa6b7_8a43a60b_540.jpg/revision/latest?cb=20210505174957';
        case 'editorial': return 'https://static.wikia.nocookie.net/aesthetics/images/d/d3/Smilewc.jpg/revision/latest?cb=20210524044251';
        case 'brutal': return 'https://static.wikia.nocookie.net/aesthetics/images/1/18/34efa0d1f1ecc17c1f8b1f4f602589b5.png/revision/latest?cb=20210327012339';
        default: return 'https://static.wikia.nocookie.net/aesthetics/images/3/3b/OIP_%2821%29.webp/revision/latest?cb=20251009135123';
    }
};
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sturmmolo | I HATE NAPOLI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

    <div class="retro-banner top-banner">
        <a href="/" class="home-btn">← HOME</a>
    </div>

    <main class="content-row">
        {posts.map((post) => (
            <a href={`/taccuino/${post.slug}`} class="post-item">
                <div class="post-label">
                    {post.data.title}
                </div>
                
                <div class="post-image-box">
                    <img src={post.data.cover || getPostImage(post.data.style)} alt={`Cover per ${post.data.title}`} class="post-real-img" />
                </div>
            </a>
        ))}
    </main>

</body>
</html>

<style is:global>
    /* --- RESET & BACKGROUND ANIMATO --- */
    :root {
        --pattern-url: url('/img/nanananna.png');
        --pattern-width: 160px;
        --pattern-height: 160px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        color: #ff0000;
        min-height: 100%;
        overflow-x: hidden;
        cursor: crosshair;
        font-family: 'Inter', Arial, sans-serif;
    }

    /* 1. Sfondo pattern obliquo anni 90 */
    body::before {
        content: "";
        position: fixed;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        z-index: -1; 
        pointer-events: none; 
        
        background-color: #e8efb6;
        background-image: var(--pattern-url);
        background-size: var(--pattern-width) var(--pattern-height);
        background-repeat: repeat;
        
        transform: rotate(45deg);
        
        image-rendering: -moz-crisp-edges;
        image-rendering: pixelated; 
        
        animation: scrollPattern 4s linear infinite;
    }

    @keyframes scrollPattern {
        0% { background-position: 0px 0px; }
        100% { background-position: var(--pattern-width) var(--pattern-height); }
    }

    /* 2. OVERLAY EFFETTO MONITOR CRT */
    body::after {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 9999; /* Sta sopra a tutto, persino al banner */
        pointer-events: none; /* FONDAMENTALE: permette di cliccare i link sottostanti */
        
        background: 
            /* Scanlines orizzontali */
            linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.15) 50%), 
            /* Vignettatura (angoli scuri tipici dei tubi catodici) */
            radial-gradient(circle at center, transparent 60%, rgba(0, 0, 0, 0.4) 100%);
        background-size: 100% 4px, 100% 100%; /* I 4px definiscono lo spessore delle righe */
        
        /* Leggero sfarfallio per realismo */
        animation: crtFlicker 0.15s infinite;
    }

    @keyframes crtFlicker {
        0% { opacity: 0.95; }
        50% { opacity: 1; }
        100% { opacity: 0.95; }
    }

    /* --- BANNER (SOLO TOP) --- */
    .retro-banner {
        position: fixed;
        left: 0;
        width: 100%;
        background-color: #000000;
        z-index: 1000;
        display: flex;
    }

    .top-banner {
        top: 0;
        height: 35px;
        align-items: center;
        justify-content: flex-start;
        padding-left: 20px;
    }

    .home-btn {
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 1.1rem;
        transition: color 0.2s, transform 0.2s;
    }

    .home-btn:hover {
        color: #ff0000;
        transform: scale(1.05);
    }

    /* --- LAYOUT CONTENUTI --- */
    .content-row {
        display: flex;
        flex-wrap: wrap; 
        justify-content: center;
        align-content: center;   
        align-items: center;     
        gap: 30px;
        min-height: 100vh;
        padding: 60px 40px 40px 40px; 
        max-width: 1400px;
        margin: 0 auto;
    }

    .post-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        width: 160px;
        transition: transform 0.2s;
    }

    .post-item:hover {
        transform: scale(1.05);
    }

    .post-label {
        color: #ff0000;
        font-weight: 700;
        font-style: italic;
        text-align: center;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 15px;
        text-transform: uppercase;
        background-color: rgba(255,255,255,0.7);
        padding: 2px 4px;
    }

    .post-image-box {
        width: 140px;
        height: 140px;
        background: #fff;
    }

    .post-real-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        image-rendering: pixelated; /* Dà alle immagini l'effetto sgranato */
    }

    /* --- RESPONSIVE MOBILE AMICHEVOLE --- */
    @media (max-width: 768px) {
        :root {
            --pattern-width: 100px;
            --pattern-height: 100px;
        }

        .content-row {
            padding: 60px 15px 40px 15px; 
            gap: 30px;
            display: flex;
            flex-direction: column;
            flex-wrap: nowrap;
            justify-content: flex-start;
            align-items: center;
        }
        
        .post-item {
            width: 100%; 
            max-width: 300px;
        }
        
        .post-label {
            font-size: 1rem; 
            margin-bottom: 10px;
        }

        /* Dimensioni notevolmente ridotte su mobile (prima era 220px) */
        .post-image-box {
            width: 150px; 
            height: 150px;
        }
    }
</style>