---
import { getCollection } from 'astro:content';

// Recuperiamo tutti gli articoli reali dalla cartella 'taccuino'
const posts = await getCollection('taccuino');

// Ordiniamo per data (dal più recente)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Funzione helper per le immagini (mantenuta nel caso in cui i tuoi post non abbiano ancora una 'cover' definita)
const getPostImage = (style: string) => {
    switch (style) {
        case 'tech': return 'https://static.wikia.nocookie.net/aesthetics/images/4/44/Tumblr_b54a31622a1e8dfa780a25c1602aa6b7_8a43a60b_540.jpg/revision/latest?cb=20210505174957';
        case 'editorial': return 'https://static.wikia.nocookie.net/aesthetics/images/d/d3/Smilewc.jpg/revision/latest?cb=20210524044251';
        case 'brutal': return 'https://static.wikia.nocookie.net/aesthetics/images/1/18/34efa0d1f1ecc17c1f8b1f4f602589b5.png/revision/latest?cb=20210327012339';
        default: return 'https://static.wikia.nocookie.net/aesthetics/images/3/3b/OIP_%2821%29.webp/revision/latest?cb=20251009135123';
    }
};
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sturmmolo | I HATE NAPOLI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Aggiunto font Inter per i titoli -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

    <!-- BANNER SUPERIORE FISSO (Nero) -->
    <div class="retro-banner top-banner">
        <a href="/" class="home-btn">← HOME</a>
    </div>

    <!-- VISTA PRINCIPALE (Centrata in orizzontale e verticale) -->
    <main class="content-row">
        {posts.map((post) => (
            /* Passiamo la descrizione a data-description per leggerla con JS */
            <a href={`/taccuino/${post.slug}`} class="post-item" data-description={post.data.description || 'Nessuna descrizione disponibile.'}>
                <!-- Titolo in alto (Rosso, Bold, Italic) -->
                <div class="post-label">
                    {post.data.title}
                </div>
                
                <!-- Immagine quadrata sotto -->
                <div class="post-image-box">
                    <!-- Se hai un'immagine frontmatter usa {post.data.cover}, altrimenti usiamo la funzione di fallback -->
                    <img src={post.data.cover || getPostImage(post.data.style)} alt={`Cover per ${post.data.title}`} class="post-real-img" />
                </div>
            </a>
        ))}
    </main>

    <!-- BANNER INFERIORE FISSO (Nero) - Mostrerà la descrizione al passaggio del mouse -->
    <div class="retro-banner bottom-banner">
        <span id="hover-description"></span>
    </div>

    <!-- SCRIPT PER EFFETTO HOVER -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const posts = document.querySelectorAll('.post-item');
            const descriptionBox = document.getElementById('hover-description');

            posts.forEach(post => {
                // Quando il mouse entra sul post, scrivi la descrizione nel banner
                post.addEventListener('mouseenter', () => {
                    const desc = post.getAttribute('data-description');
                    if (desc) {
                        descriptionBox.textContent = desc;
                    }
                });

                // Quando il mouse esce, svuota il banner
                post.addEventListener('mouseleave', () => {
                    descriptionBox.textContent = '';
                });
            });
        });
    </script>

</body>
</html>

<style is:global>
    /* --- RESET & BACKGROUND ANIMATO --- */
    :root {
        /* Percorso dell'immagine locale inserita in public/img/ */
        --pattern-url: url('/img/nanananna.png');
        
        /* Uso i pixel fissi al posto di vw/vh per evitare qualsiasi deformazione dell'immagine.
           Se la tua immagine non è perfettamente quadrata, adatta questi valori (es. 160px e 120px) */
        --pattern-width: 160px;
        --pattern-height: 160px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #e8efb6; /* Un colore di fallback nel caso l'immagine sia trasparente */
        color: #ff0000;
        min-height: 100%;
        overflow-x: hidden;
        cursor: crosshair;
        font-family: 'Inter', Arial, sans-serif;
        
        /* Logica del background animato */
        background-image: var(--pattern-url);
        background-size: var(--pattern-width) var(--pattern-height);
        background-repeat: repeat;
        animation: scrollPattern 4s linear infinite;
    }

    @keyframes scrollPattern {
        0% { background-position: 0px 0px; }
        100% { background-position: var(--pattern-width) var(--pattern-height); }
    }

    /* --- BANNER (TOP & BOTTOM) - ORA NERI --- */
    .retro-banner {
        position: fixed;
        left: 0;
        width: 100%;
        background-color: #000000; /* Modificato da rosso a nero */
        z-index: 1000;
        display: flex;
        justify-content: center; /* Centra il contenuto orizzontalmente */
    }

    /* Stile specifico per il banner top fisso */
    .top-banner {
        top: 0;
        height: 35px; /* Altezza fissa solo per quello in alto */
        align-items: center;
    }

    .home-btn {
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        font-family: Arial, Helvetica, sans-serif; /* Adattato allo screen */
        font-size: 1.1rem; /* Leggermente più grande */
        transition: color 0.2s, transform 0.2s;
    }

    .home-btn:hover {
        color: #ff0000; /* Hover rosso per contrastare col banner nero */
        transform: scale(1.05);
    }

    /* Banner inferiore per la descrizione (ora supporta altezze maggiori) */
    .bottom-banner {
        bottom: 0;
        min-height: 80px; /* Abbastanza spazio per contenere circa 3 righe */
        align-items: center; /* Centra il testo verticalmente */
    }

    #hover-description {
        color: #ffffff;
        font-family: Arial, Helvetica, sans-serif; /* Adattato allo screen per un look più pulito */
        font-size: 1.25rem; /* Font aumentato su desktop */
        font-weight: 700;
        white-space: normal;
        display: -webkit-box;
        -webkit-line-clamp: 3; /* Blocca il testo alla terza riga */
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        padding: 10px 20px;
        max-width: 100%;
        text-align: center;
        line-height: 1.4;
    }

    /* --- LAYOUT CONTENUTI (Orizzontale & Centrato) --- */
    .content-row {
        display: flex;
        flex-wrap: wrap; 
        justify-content: center; /* Centra orizzontalmente */
        align-content: center;   /* Centra il blocco di post verticalmente */
        align-items: center;     /* Centra i singoli elementi verticalmente */
        gap: 30px;
        min-height: 100vh;
        /* Padding modificato per lasciare più spazio al banner inferiore */
        padding: 60px 40px 100px 40px; 
        max-width: 1400px;
        margin: 0 auto;
    }

    .post-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        width: 160px; /* Larghezza fissa della colonna desktop */
        transition: transform 0.2s;
    }

    .post-item:hover {
        transform: scale(1.05); /* Effetto hover semplice */
    }

    /* Etichetta Titolo (rossa, bold, italic) */
    .post-label {
        color: #ff0000;
        font-weight: 700;
        font-style: italic;
        text-align: center;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 15px;
        text-transform: uppercase;
        background-color: rgba(255,255,255,0.7); /* Per leggibilità sul pattern */
        padding: 2px 4px;
    }

    /* Immagine quadrata */
    .post-image-box {
        width: 140px;
        height: 140px;
        background: #fff;
    }

    .post-real-img {
        width: 100%;
        height: 100%;
        object-fit: cover; /* Assicura che l'immagine riempia il quadrato senza deformarsi */
    }

    /* --- RESPONSIVE MOBILE AMICHEVOLE --- */
    @media (max-width: 768px) {
        :root {
            /* Dimensioni del pattern ridotte per mobile per non invadere troppo,
               sempre in pixel fissi per azzerare le deformazioni */
            --pattern-width: 100px;
            --pattern-height: 100px;
        }

        .content-row {
            padding: 60px 15px 140px 15px; /* Aumentato ulteriormente il padding inferiore per il banner nero fisso più alto */
            gap: 40px; /* Spazio verticale netto tra i post in colonna */
            /* Su mobile passiamo a una visualizzazione a singola colonna */
            display: flex;
            flex-direction: column;
            flex-wrap: nowrap;
            justify-content: flex-start;
            align-items: center;
        }
        
        .post-item {
            width: 90%; /* Occupa gran parte della larghezza dello schermo */
            max-width: 400px; /* Limite massimo per dispositivi grandi */
        }
        
        /* Adeguiamo il testo alla nuova larghezza */
        .post-label {
            font-size: 1.1rem; 
            margin-bottom: 10px;
        }

        /* Rendiamo l'immagine fluida e proporzionata rispetto alla larghezza dello schermo */
        .post-image-box {
            width: 100%; 
            height: auto;
            aspect-ratio: 1 / 1; /* Mantiene sempre il quadrato perfetto */
        }
        
        .bottom-banner {
            min-height: 110px; /* Aumentiamo l'altezza del banner su mobile per ospitare testo più grande */
        }

        #hover-description {
            font-size: 1.15rem; /* Font più grande e molto più leggibile su mobile */
            padding: 10px 8px; /* Padding laterale ridotto in modo da sfruttare tutto lo spazio disponibile */
        }
    }
</style>