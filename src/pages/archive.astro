---
import { getCollection } from 'astro:content';

// 1. Recupero degli articoli
const posts = await getCollection('taccuino');

// 2. FUNZIONI GENERATIVE PER L'ARTWORK SVG
const generateCyanLines = () => {
    let paths = [];
    for (let i = 0; i < 8; i++) {
        let path = `M ${Math.random() * 100} ${Math.random() * 10}`;
        for (let j = 0; j < 5; j++) {
            path += ` L ${Math.random() * 100} ${Math.random() * 100}`;
        }
        paths.push(path);
    }
    return paths;
};

const generateTopoLines = () => {
    let paths = [];
    const peaks = [
        { cx: 20, cy: 80, layers: 15, radius: 25 },
        { cx: 60, cy: 40, layers: 20, radius: 35 },
        { cx: 85, cy: 30, layers: 10, radius: 15 }
    ];

    peaks.forEach(peak => {
        for (let l = 1; l <= peak.layers; l++) {
            let points = [];
            let currentRadius = (l / peak.layers) * peak.radius;
            for (let angle = 0; angle < 360; angle += 20) {
                let jitter = (Math.random() - 0.5) * 4; 
                let r = currentRadius + jitter;
                let x = peak.cx + r * Math.cos((angle * Math.PI) / 180);
                let y = peak.cy + r * Math.sin((angle * Math.PI) / 180);
                points.push(`${x},${y}`);
            }
            paths.push(`M ${points.join(' L ')} Z`);
        }
    });
    return paths;
};

const generateNumbers = () => {
    let numbers = [];
    for (let i = 0; i < 30; i++) {
        numbers.push({
            x: Math.random() * 95,
            y: Math.random() * 95,
            val: Math.floor(Math.random() * 40 + 50) 
        });
    }
    return numbers;
};

const cyanPaths = generateCyanLines();
const topoPaths = generateTopoLines();
const mapNumbers = generateNumbers();

// 3. LOGICA PER GLI ARTICOLI 
const nonsenseSubtexts = ["message.hqx", "131.24.167", "Reflector", "SYS.ERR", "BINHEX"];
const glitchSymbols = ['†', 'º', '‡', '±'];

// Array di posizioni orizzontali in percentuale (vw)
const leftPositions = [10, 55, 20, 60, 15, 50, 25];
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>%Taccuino&</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

    <svg class="jodi-bg" viewBox="0 0 100 100" preserveAspectRatio="none">
        {cyanPaths.map(path => (
            <path d={path} fill="none" stroke="#00ffff" stroke-width="0.3" vector-effect="non-scaling-stroke" class="cyan-line" />
        ))}
        {topoPaths.map(path => (
            <path d={path} fill="none" stroke="#ffff00" stroke-width="0.2" vector-effect="non-scaling-stroke" />
        ))}
        {mapNumbers.map(num => (
            <text x={num.x} y={num.y} fill="#ffff00" font-size="2" font-family="monospace">
                {num.val}
            </text>
        ))}
        <circle cx="20" cy="80" r="1.5" fill="none" stroke="#ff0000" stroke-width="0.5" vector-effect="non-scaling-stroke" />
        <circle cx="20" cy="80" r="0.4" fill="#ff0000" />
        <circle cx="60" cy="40" r="1.5" fill="none" stroke="#ff0000" stroke-width="0.5" vector-effect="non-scaling-stroke" />
        <circle cx="60" cy="40" r="0.4" fill="#ff0000" />
    </svg>

    <main class="ui-layer">

        <a href="/" class="home-link">
            "HOME=
        </a>

        <div class="articles-container">
            {posts.map((post, index) => {
                const posLeft = leftPositions[index % leftPositions.length];
                const symbol = glitchSymbols[index % glitchSymbols.length];
                const subtext = nonsenseSubtexts[index % nonsenseSubtexts.length];

                return (
                    <div class="article-node" style={`--offset-x: ${posLeft}vw;`}>
                        <a href={`/taccuino/${post.slug}`} class="main-title">
                            {post.data.title.toUpperCase()}{symbol}
                        </a>
                        <div class="sub-title">{subtext}</div>
                    </div>
                );
            })}
        </div>

    </main>

</body>
</html>

<style is:global>
    /* --- RESET & SETUP --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #000000;
        min-height: 100vh;
        overflow-x: hidden; 
        overflow-y: auto;   
        font-family: Arial, Helvetica, sans-serif; 
        cursor: crosshair;
    }

    /* --- BACKGROUND SVG --- */
    .jodi-bg {
        position: fixed; 
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1;
        pointer-events: none; 
    }

    .cyan-line {
        animation: glitchPath 4s infinite step-end;
    }

    @keyframes glitchPath {
        90% { stroke-opacity: 1; }
        95% { stroke-opacity: 0.2; }
        100% { stroke-opacity: 1; }
    }

    /* --- LAYER UI HTML --- */
    .ui-layer {
        position: relative;
        width: 100%;
        z-index: 10;
    }

    /* --- LAYOUT ARTICOLI --- */
    .articles-container {
        display: flex;
        flex-direction: column;
        gap: 25vh; 
        padding-top: 15vh; 
        padding-bottom: 20vh; 
    }

    /* --- HOME LINK --- */
    .home-link {
        position: fixed; 
        top: 5%;
        left: 5%;
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 26px;
        font-weight: 900;
        letter-spacing: 1px;
        background-color: rgba(0, 0, 0, 0.6); 
        padding: 2px 6px;
        z-index: 100;
    }

    .home-link:hover {
        background-color: #ff0000;
        color: #000000;
        text-decoration: none;
    }

    /* --- ARTICOLI --- */
    .article-node {
        position: relative; 
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        background-color: rgba(0, 0, 0, 0.6); 
        padding: 4px 8px;
        
        margin-left: var(--offset-x);
        width: fit-content;
        max-width: calc(92vw - var(--offset-x)); 
    }

    .main-title {
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 1px;
        
        white-space: normal; 
        word-wrap: break-word; 
        line-height: 1.1; 
    }

    .main-title:hover {
        background-color: #ff0000;
        color: #000000;
        text-decoration: none;
    }

    .sub-title {
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        font-size: 22px;
        font-weight: 700;
        margin-top: 2px;
        pointer-events: none;
        word-wrap: break-word;
    }

    /* --- MOBILE --- */
    @media (max-width: 768px) {
        .main-title { font-size: 20px; text-decoration-thickness: 2px; }
        .sub-title { font-size: 16px; }
        .home-link { font-size: 20px; top: 3%; left: 3%; }
        .articles-container { gap: 20vh; } 
        
        .article-node {
            margin-left: calc(var(--offset-x) * 0.2);
            max-width: calc(94vw - calc(var(--offset-x) * 0.2));
        }
    }
</style>