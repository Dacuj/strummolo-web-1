---
import { getCollection } from 'astro:content';

// Recuperiamo tutti gli articoli reali dalla cartella 'taccuino'
const posts = await getCollection('taccuino');

// Ordiniamo per data (dal più recente)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Funzione helper per formattare la data
const formatDate = (date: Date) => {
    return new Intl.DateTimeFormat('it-IT', { day: '2-digit', month: '2-digit', year: 'numeric' }).format(date);
};

// Generatore di Immagini Sottoculture (Weirdcore / Vaporwave / Y2K / Punk)
const getWeirdcoreImage = (style: string) => {
    switch (style) {
        case 'tech': return 'https://static.wikia.nocookie.net/aesthetics/images/4/44/Tumblr_b54a31622a1e8dfa780a25c1602aa6b7_8a43a60b_540.jpg/revision/latest?cb=20210505174957';
        case 'editorial': return 'https://static.wikia.nocookie.net/aesthetics/images/d/d3/Smilewc.jpg/revision/latest?cb=20210524044251';
        case 'brutal': return 'https://static.wikia.nocookie.net/aesthetics/images/1/18/34efa0d1f1ecc17c1f8b1f4f602589b5.png/revision/latest?cb=20210327012339';
        case 'notebook': return 'https://static.wikia.nocookie.net/aesthetics/images/3/3b/OIP_%2821%29.webp/revision/latest?cb=20251009135123';
        default: return 'https://static.wikia.nocookie.net/aesthetics/images/d/d3/Smilewc.jpg/revision/latest?cb=20210524044251';
    }
};

// Generatore di stili caotici e font Web 1.0 per le etichette
const weirdFonts = ['"Comic Sans MS", cursive', '"Courier New", Courier, monospace', '"Times New Roman", Times, serif', '"Pixelify Sans", sans-serif'];
const weirdColors = ['#00FFFF', '#FF00FF', '#39FF14', '#FFFF00', '#FF3333', '#FFFFFF'];

const getLabelStyle = (index: number) => {
    const font = weirdFonts[index % weirdFonts.length];
    const color = weirdColors[(index * 5) % weirdColors.length];
    
    // Simula l'effetto del testo "evidenziato" tipico dei vecchi siti
    const isHighlighted = index % 3 === 0;
    const bg = isHighlighted ? '#000080' : 'transparent';
    const border = isHighlighted ? `1px dotted ${color}` : 'none';
    
    return `font-family: ${font}; color: ${color}; background-color: ${bg}; border: ${border};`;
};

// Spargimento caotico per le icone
const getScatteredStyle = (index: number) => {
    const offsetX = (index * 47) % 100 - 50; 
    const offsetY = (index * 83) % 100 - 50;
    const rotate = (index * 13) % 14 - 7; // Lieve rotazione tra -7 e +7 gradi per un effetto più crudo
    // Generiamo variabili CSS per poter scalare l'effetto su mobile
    return `--off-x: ${offsetX}px; --off-y: ${offsetY}px; --rot: ${rotate}deg;`;
};
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>strummolo | THE VOID ARCHIVE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@900&family=Playfair+Display:ital,wght@1,400;1,700&family=Space+Mono:wght@400;700&family=Pixelify+Sans:wght@400;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

    <!-- Controlli Fissi (Navigazione) -->
    <div class="nav-controls">
        <a href="/" class="action-badge">← HOME</a>
    </div>

    <!-- ========================================== -->
    <!-- VISTA UNICA: WEIRDCORE / VAPORWAVE         -->
    <!-- ========================================== -->
    <main class="weird-area">
        {posts.map((post, index) => (
            <a href={`/taccuino/${post.slug}`} class="weird-item" style={getScatteredStyle(index)}>
                
                <!-- Contenitore immagine reale -->
                <div class={`weird-image-box img-filter-${index % 4}`}>
                    <img src={getWeirdcoreImage(post.data.style)} alt={`Cover per ${post.data.title}`} class="weird-real-img" />
                </div>
                
                <div class="weird-label" style={getLabelStyle(index)}>
                    {post.data.title}
                </div>
                
            </a>
        ))}
    </main>

</body>
</html>

<style is:global>
    /* --- RESET --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #000;
        color: #fff;
        overflow-x: hidden;
        min-height: 100%;
        cursor: crosshair;
    }

    /* --- BADGES (Home) --- */
    .nav-controls {
        position: fixed;
        top: 30px;
        left: 30px;
        z-index: 9999;
        pointer-events: none; 
    }

    .action-badge {
        pointer-events: auto;
        background: #000;
        color: #fff;
        font-family: 'Space Mono', monospace;
        font-weight: 700;
        text-decoration: none;
        padding: 10px 15px;
        text-transform: uppercase;
        font-size: 1rem;
        border: 2px solid #fff;
        box-shadow: 4px 4px 0px #fff;
        transition: transform 0.1s, box-shadow 0.1s;
        cursor: pointer;
        display: inline-block;
    }

    .action-badge:hover {
        transform: translate(2px, 2px);
        box-shadow: 2px 2px 0px #fff;
        background: #fff;
        color: #000;
    }

    /* ================================================== */
    /* VISTA 1: WEIRDCORE / VAPORWAVE STYLES              */
    /* ================================================== */

    .weird-area {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        grid-auto-rows: 200px;
        gap: 50px;
        padding: 150px 40px 100px 40px;
        max-width: 1400px;
        margin: 0 auto;
        justify-items: center;
        align-items: center;
    }

    .weird-item {
        position: relative;
        z-index: 10;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 160px;
        transition: z-index 0.1s;
        /* Applica lo scatter tramite le variabili CSS impostate in JS */
        transform: translate(var(--off-x), var(--off-y)) rotate(var(--rot));
    }

    .weird-item:hover {
        z-index: 100;
    }

    /* Stile Contenitore Immagini e Immagini stesse */
    .weird-image-box {
        width: 120px;
        height: 120px;
        margin-bottom: 15px;
        border: 2px solid #333; /* Bordo grezzo default */
        background: #111;
        overflow: hidden;
        transition: border-color 0.1s;
    }

    .weird-real-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        /* Fa in modo che il placeholder testuale alternativo (alt) sia stilizzato se l'immagine non carica */
        color: #fff;
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.7rem;
        display: block;
        text-align: center;
        line-height: 1.2;
    }

    /* Variazioni di filtri sulle immagini per l'effetto weirdcore/glitch */
    .img-filter-0 .weird-real-img { filter: contrast(150%) saturate(200%) hue-rotate(90deg); }
    .img-filter-1 .weird-real-img { filter: grayscale(100%) contrast(200%); }
    .img-filter-2 .weird-real-img { filter: sepia(100%) hue-rotate(-50deg) saturate(300%); }
    .img-filter-3 .weird-real-img { filter: invert(100%) hue-rotate(180deg); }

    .weird-item:hover .weird-image-box {
        border-color: #fff;
    }

    /* Testo con i font grezzi Web 1.0 */
    .weird-label {
        font-size: 1rem;
        font-weight: bold;
        text-align: center;
        padding: 4px 8px;
        line-height: 1.2;
        text-shadow: 2px 2px 0px #000; /* Leggibilità sul nero */
        word-wrap: break-word;
        max-width: 100%;
        transition: all 0.1s;
    }

    .weird-item:hover .weird-label {
        background-color: #fff !important;
        color: #000 !important;
        text-shadow: none;
        border: 1px solid #000 !important;
    }

    /* --- MOBILE RESPONSIVE --- */
    @media (max-width: 768px) {
        .nav-controls {
            top: 15px;
            left: 15px;
        }

        .action-badge {
            padding: 8px 12px;
            font-size: 0.85rem;
        }

        /* Weirdcore view mobile */
        .weird-area {
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            padding: 140px 15px 50px 15px; 
            justify-items: center;
        }

        .weird-item {
            width: 120px;
            /* Su mobile riduciamo matematicamente lo spargimento del 50% per evitare overflow estremo ma mantenere il caos intatto */
            transform: translate(calc(var(--off-x) * 0.5), calc(var(--off-y) * 0.5)) rotate(var(--rot));
        }

        .weird-image-box {
            width: 90px;
            height: 90px;
        }

        .weird-label {
            font-size: 0.85rem;
        }
    }
</style>