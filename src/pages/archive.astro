---
import { getCollection } from 'astro:content';

// 1. Recupero degli articoli
const posts = await getCollection('taccuino');

// 2. FUNZIONI GENERATIVE PER L'ARTWORK SVG
// Generiamo linee azzurre "spezzate" simili a confini radar/fiumi
const generateCyanLines = () => {
    let paths = [];
    for (let i = 0; i < 8; i++) {
        let path = `M ${Math.random() * 100} ${Math.random() * 10}`;
        for (let j = 0; j < 5; j++) {
            path += ` L ${Math.random() * 100} ${Math.random() * 100}`;
        }
        paths.push(path);
    }
    return paths;
};

// Generiamo linee topografiche gialle (cerchi concentrici distorti)
const generateTopoLines = () => {
    let paths = [];
    const peaks = [
        { cx: 20, cy: 80, layers: 15, radius: 25 }, // Picco in basso a sx
        { cx: 60, cy: 40, layers: 20, radius: 35 }, // Picco centrale
        { cx: 85, cy: 30, layers: 10, radius: 15 }  // Picco in alto a dx
    ];

    peaks.forEach(peak => {
        for (let l = 1; l <= peak.layers; l++) {
            let points = [];
            let currentRadius = (l / peak.layers) * peak.radius;
            for (let angle = 0; angle < 360; angle += 20) {
                // Distorsione matematica (rumore casuale)
                let jitter = (Math.random() - 0.5) * 4; 
                let r = currentRadius + jitter;
                let x = peak.cx + r * Math.cos((angle * Math.PI) / 180);
                let y = peak.cy + r * Math.sin((angle * Math.PI) / 180);
                points.push(`${x},${y}`);
            }
            paths.push(`M ${points.join(' L ')} Z`);
        }
    });
    return paths;
};

// Generiamo i numeretti sparsi (es. 64, 56, 90)
const generateNumbers = () => {
    let numbers = [];
    for (let i = 0; i < 30; i++) {
        numbers.push({
            x: Math.random() * 95,
            y: Math.random() * 95,
            val: Math.floor(Math.random() * 40 + 50) 
        });
    }
    return numbers;
};

// Eseguiamo i calcoli per il background
const cyanPaths = generateCyanLines();
const topoPaths = generateTopoLines();
const mapNumbers = generateNumbers();

// 3. LOGICA PER GLI ARTICOLI (Scritte Rosse)
const getRandomPos = () => ({
    // Range tra 15% e 80% per lasciare libero l'angolo in alto a sinistra per la HOME
    top: Math.floor(Math.random() * 65 + 15) + '%',
    left: Math.floor(Math.random() * 65 + 15) + '%'
});

const nonsenseSubtexts = ["message.hqx", "131.24.167", "Reflector", "SYS.ERR", "BINHEX"];
const glitchSymbols = ['†', 'º', '‡', '±'];
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BETALAB // I HATE NAPOLI</title>
</head>
<body>

    <!-- ARTWORK GENERATO VIA CODICE (SVG) -->
    <svg class="jodi-bg" viewBox="0 0 100 100" preserveAspectRatio="none">
        
        <!-- Confini azzurri -->
        {cyanPaths.map(path => (
            <path d={path} fill="none" stroke="#00ffff" stroke-width="0.3" vector-effect="non-scaling-stroke" class="cyan-line" />
        ))}

        <!-- Topografia gialla -->
        {topoPaths.map(path => (
            <path d={path} fill="none" stroke="#ffff00" stroke-width="0.2" vector-effect="non-scaling-stroke" />
        ))}

        <!-- Numeri gialli sparsi -->
        {mapNumbers.map(num => (
            <text x={num.x} y={num.y} fill="#ffff00" font-size="2" font-family="monospace">
                {num.val}
            </text>
        ))}

        <!-- Bersagli topografici Rossi in SVG -->
        <circle cx="20" cy="80" r="1.5" fill="none" stroke="#ff0000" stroke-width="0.5" vector-effect="non-scaling-stroke" />
        <circle cx="20" cy="80" r="0.4" fill="#ff0000" />
        
        <circle cx="60" cy="40" r="1.5" fill="none" stroke="#ff0000" stroke-width="0.5" vector-effect="non-scaling-stroke" />
        <circle cx="60" cy="40" r="0.4" fill="#ff0000" />

    </svg>

    <!-- LIVELLO SUPERIORE HTML: UI e ARTICOLI -->
    <main class="ui-layer">

        <!-- IL LINK HOME IN ALTO A SINISTRA -->
        <a href="/" class="home-link">
            "HOME=
        </a>

        <!-- GLI ARTICOLI SPARSI -->
        {posts.map((post) => {
            const pos = getRandomPos();
            const symbol = glitchSymbols[Math.floor(Math.random() * glitchSymbols.length)];
            const subtext = nonsenseSubtexts[Math.floor(Math.random() * nonsenseSubtexts.length)];

            return (
                <div class="article-node" style={`top: ${pos.top}; left: ${pos.left};`}>
                    <a href={`/taccuino/${post.slug}`} class="main-title">
                        {post.data.title.toUpperCase()}{symbol}
                    </a>
                    <div class="sub-title">{subtext}</div>
                </div>
            );
        })}

        <!-- TORRETTA FINTA DECORATIVA -->
        <div class="fake-target" style="bottom: 15%; right: 25%;">
            "target=
            <div class="beacon-tower">
                <div class="beacon-light"></div>
                <div class="beacon-base"></div>
            </div>
        </div>
    </main>

</body>
</html>

<style is:global>
    /* --- RESET & SETUP --- */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #000000;
        height: 100vh;
        width: 100vw;
        overflow: hidden; 
        font-family: Arial, Helvetica, sans-serif; 
        cursor: crosshair;
    }

    /* --- BACKGROUND SVG --- */
    .jodi-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        z-index: 1;
        pointer-events: none; 
    }

    .cyan-line {
        animation: glitchPath 4s infinite step-end;
    }

    @keyframes glitchPath {
        90% { stroke-opacity: 1; }
        95% { stroke-opacity: 0.2; }
        100% { stroke-opacity: 1; }
    }

    /* --- LAYER UI HTML --- */
    .ui-layer {
        position: relative;
        width: 100%;
        height: 100%;
        z-index: 10;
    }

    /* --- HOME LINK --- */
    .home-link {
        position: absolute;
        top: 5%;
        left: 5%;
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 26px;
        font-weight: 900;
        letter-spacing: 1px;
        background-color: rgba(0, 0, 0, 0.6); 
        padding: 2px 6px;
        z-index: 100; /* Assicuriamoci che stia sempre sopra a tutto */
    }

    .home-link:hover {
        background-color: #ff0000;
        color: #000000;
        text-decoration: none;
    }

    /* --- ARTICOLI --- */
    .article-node {
        position: absolute;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        background-color: rgba(0, 0, 0, 0.6); 
        padding: 2px 6px;
    }

    .main-title {
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 3px;
        font-size: 28px;
        font-weight: 900;
        letter-spacing: 1px;
    }

    .main-title:hover {
        background-color: #ff0000;
        color: #000000;
        text-decoration: none;
    }

    .sub-title {
        color: #ff0000;
        text-decoration: underline;
        text-decoration-thickness: 2px;
        font-size: 22px;
        font-weight: 700;
        margin-top: -2px;
        pointer-events: none; /* Rende la sottoscritta non cliccabile per non infastidire */
    }

    /* --- DECORAZIONE TORRETTA RADAR ("target=") --- */
    .fake-target {
        position: absolute;
        color: #ff0000;
        text-decoration: underline;
        font-size: 24px;
        font-weight: bold;
        display: flex;
        flex-direction: column;
        align-items: center;
        pointer-events: none;
    }

    .beacon-tower {
        margin-top: 5px;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .beacon-base {
        width: 0;
        height: 0;
        border-left: 8px solid transparent;
        border-right: 8px solid transparent;
        border-bottom: 20px solid #ff0000;
    }

    .beacon-light {
        width: 6px;
        height: 6px;
        background-color: #ff0000;
        margin-bottom: 2px;
        animation: beaconBlink 0.8s infinite step-end;
    }

    @keyframes beaconBlink {
        50% { opacity: 0; }
    }

    /* --- MOBILE --- */
    @media (max-width: 768px) {
        .main-title { font-size: 20px; text-decoration-thickness: 2px; }
        .sub-title { font-size: 16px; }
        .home-link { font-size: 20px; top: 3%; left: 3%; }
        .fake-target { font-size: 18px; }
        body, html { overflow: auto; } 
    }
</style>