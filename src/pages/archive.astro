---
import { getCollection } from 'astro:content';

// Recuperiamo tutti gli articoli reali dalla cartella 'taccuino'
const posts = await getCollection('taccuino');

// Ordiniamo per data (dal più recente)
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Funzione helper per le immagini (mantenuta nel caso in cui i tuoi post non abbiano ancora una 'cover' definita)
const getPostImage = (style: string) => {
    switch (style) {
        case 'tech': return 'https://static.wikia.nocookie.net/aesthetics/images/4/44/Tumblr_b54a31622a1e8dfa780a25c1602aa6b7_8a43a60b_540.jpg/revision/latest?cb=20210505174957';
        case 'editorial': return 'https://static.wikia.nocookie.net/aesthetics/images/d/d3/Smilewc.jpg/revision/latest?cb=20210524044251';
        case 'brutal': return 'https://static.wikia.nocookie.net/aesthetics/images/1/18/34efa0d1f1ecc17c1f8b1f4f602589b5.png/revision/latest?cb=20210327012339';
        default: return 'https://static.wikia.nocookie.net/aesthetics/images/3/3b/OIP_%2821%29.webp/revision/latest?cb=20251009135123';
    }
};
---

<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sturmmolo | I HATE NAPOLI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>

    <div class="retro-banner top-banner">
        <a href="/" class="home-btn">← HOME</a>
    </div>

    <main class="content-row">
        {posts.map((post) => (
            <a href={`/taccuino/${post.slug}`} class="post-item" data-description={post.data.description || 'Nessuna descrizione disponibile.'}>
                <div class="post-label">
                    {post.data.title}
                </div>
                
                <div class="post-image-box">
                    <img src={post.data.cover || getPostImage(post.data.style)} alt={`Cover per ${post.data.title}`} class="post-real-img" />
                </div>
            </a>
        ))}
    </main>

    <div class="retro-banner bottom-banner">
        <span id="hover-description"></span>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const posts = document.querySelectorAll('.post-item');
            const descriptionBox = document.getElementById('hover-description');

            posts.forEach(post => {
                post.addEventListener('mouseenter', () => {
                    const desc = post.getAttribute('data-description');
                    if (desc) {
                        descriptionBox.textContent = desc;
                    }
                });

                post.addEventListener('mouseleave', () => {
                    descriptionBox.textContent = '';
                });
            });
        });
    </script>

</body>
</html>

<style is:global>
    /* --- RESET & BACKGROUND ANIMATO --- */
    :root {
        --pattern-url: url('/img/nanananna.png');
        --pattern-width: 160px;
        --pattern-height: 160px;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body, html {
        background-color: #e8efb6;
        color: #ff0000;
        min-height: 100%;
        overflow-x: hidden;
        cursor: crosshair;
        font-family: 'Inter', Arial, sans-serif;
        
        background-image: var(--pattern-url);
        background-size: var(--pattern-width) var(--pattern-height);
        background-repeat: repeat;
        animation: scrollPattern 4s linear infinite;
    }

    @keyframes scrollPattern {
        0% { background-position: 0px 0px; }
        100% { background-position: var(--pattern-width) var(--pattern-height); }
    }

    /* --- BANNER (TOP & BOTTOM) --- */
    .retro-banner {
        position: fixed;
        left: 0;
        width: 100%;
        background-color: #000000;
        z-index: 1000;
        display: flex;
    }

    /* Top banner: allineato a sinistra */
    .top-banner {
        top: 0;
        height: 35px;
        align-items: center;
        justify-content: flex-start; /* Sposta il bottone a sinistra */
        padding-left: 20px; /* Dà respiro dal bordo sinistro */
    }

    .home-btn {
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 1.1rem;
        transition: color 0.2s, transform 0.2s;
    }

    .home-btn:hover {
        color: #ff0000;
        transform: scale(1.05);
    }

    /* Bottom banner: centrato */
    .bottom-banner {
        bottom: 0;
        min-height: 80px;
        align-items: center;
        justify-content: center; /* Centra il testo della descrizione */
    }

    #hover-description {
        color: #ffffff;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        white-space: normal;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        padding: 10px 20px;
        max-width: 100%;
        text-align: center;
        line-height: 1.4;
    }

    /* --- LAYOUT CONTENUTI --- */
    .content-row {
        display: flex;
        flex-wrap: wrap; 
        justify-content: center;
        align-content: center;   
        align-items: center;     
        gap: 30px;
        min-height: 100vh;
        padding: 60px 40px 100px 40px; 
        max-width: 1400px;
        margin: 0 auto;
    }

    .post-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
        width: 160px;
        transition: transform 0.2s;
    }

    .post-item:hover {
        transform: scale(1.05);
    }

    .post-label {
        color: #ff0000;
        font-weight: 700;
        font-style: italic;
        text-align: center;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 15px;
        text-transform: uppercase;
        background-color: rgba(255,255,255,0.7);
        padding: 2px 4px;
    }

    .post-image-box {
        width: 140px;
        height: 140px;
        background: #fff;
    }

    .post-real-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* --- RESPONSIVE MOBILE AMICHEVOLE --- */
    @media (max-width: 768px) {
        :root {
            --pattern-width: 100px;
            --pattern-height: 100px;
        }

        .content-row {
            /* Ridotto il padding inferiore visto che il banner nero sotto non c'è più */
            padding: 60px 15px 40px 15px; 
            gap: 40px;
            display: flex;
            flex-direction: column;
            flex-wrap: nowrap;
            justify-content: flex-start;
            align-items: center;
        }
        
        .post-item {
            width: 100%; 
            max-width: 400px;
        }
        
        .post-label {
            font-size: 1.1rem; 
            margin-bottom: 10px;
        }

        /* Dimensioni fisse ridotte per l'immagine invece del 100% */
        .post-image-box {
            width: 220px; 
            height: 220px;
        }
        
        /* Nascondiamo completamente il banner inferiore su mobile */
        .bottom-banner {
            display: none;
        }
    }
</style>