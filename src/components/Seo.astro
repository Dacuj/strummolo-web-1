---
// Componente SEO riutilizzabile: title, description, canonical, robots,
// Open Graph, Twitter Card e (opzionale) JSON-LD strutturato.
interface Props {
  title: string;
  description: string;
  canonical?: string | URL;
  image?: string;            // path o URL assoluto dell'immagine di condivisione
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
  publishedTime?: string;    // ISO date, solo per type="article"
  jsonLd?: Record<string, any> | Record<string, any>[];
}

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  noindex = false,
  publishedTime,
  jsonLd,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.strummolo.com');
const canonicalURL = canonical
  ? new URL(canonical.toString(), siteUrl)
  : new URL(Astro.url.pathname, siteUrl);

const DEFAULT_IMAGE = new URL('/favicon.png', siteUrl).href;
const ogImage = image ? new URL(image, siteUrl).href : DEFAULT_IMAGE;

const SITE_NAME = 'strummolo';
const TWITTER_HANDLE = '@strummolo123';
---
{/* Content-Security-Policy del sito pubblico.
    Impostata qui via <meta> e NON via _headers: su Cloudflare Pages la regola /*
    diventerebbe un secondo header CSP anche su /admin (gli header si sommano),
    bloccando Decap CMS. frame-ancestors è omesso perché ignorato nei <meta>
    (la protezione clickjacking è data dall'header X-Frame-Options in _headers). */}
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; object-src 'none'; form-action 'self'; img-src 'self' data: https://res.cloudinary.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline'; connect-src 'self' https://chat-api.davidecucciardi.workers.dev; upgrade-insecure-requests" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL.href} />
{noindex
  ? <meta name="robots" content="noindex, nofollow" />
  : <meta name="robots" content="index, follow, max-image-preview:large" />
}

{/* Open Graph */}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content="it_IT" />
{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}

{/* Twitter Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:site" content={TWITTER_HANDLE} />

{/* Icone */}
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
<link rel="manifest" href="/site.webmanifest" />

{jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
